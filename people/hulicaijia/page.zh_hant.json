"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({a:\"a\",blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components),PhotoScroll=_components.PhotoScroll,Sakura=_components.Sakura;if(!PhotoScroll)_missingMdxReference(\"PhotoScroll\",true);if(!Sakura)_missingMdxReference(\"Sakura\",true);return Vue.h(Vue.Fragment,null,Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,Vue.h(\"svg\",{style:\"display: inline-block; overflow: visible !important; vertical-align: sub; fill: rgb(26, 127, 55); margin-right: 10px;\",viewBox:\"0 0 16 16\",version:\"1.1\",width:\"16\",height:\"16\",\"aria-hidden\":\"true\"},Vue.h(\"path\",{d:\"M8 1.5c-2.363 0-4 1.69-4 3.75 0 .984.424 1.625.984 2.304l.214.253c.223.264.47.556.673.848.284.411.537.896.621 1.49a.75.75 0 0 1-1.484.211c-.04-.282-.163-.547-.37-.847a8.456 8.456 0 0 0-.542-.68c-.084-.1-.173-.205-.268-.32C3.201 7.75 2.5 6.766 2.5 5.25 2.5 2.31 4.863 0 8 0s5.5 2.31 5.5 5.25c0 1.516-.701 2.5-1.328 3.259-.095.115-.184.22-.268.319-.207.245-.383.453-.541.681-.208.3-.33.565-.37.847a.751.751 0 0 1-1.485-.212c.084-.593.337-1.078.621-1.489.203-.292.45-.584.673-.848.075-.088.147-.173.213-.253.561-.679.985-1.32.985-2.304 0-2.06-1.637-3.75-4-3.75ZM5.75 12h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1 0-1.5ZM6 15.25a.75.75 0 0 1 .75-.75h2.5a.75.75 0 0 1 0 1.5h-2.5a.75.75 0 0 1-.75-.75Z\"})),\" 閱讀提示：本文因敘事完整性與連貫性的需要，破例保留了部分涉及藥物濫用與敏感用藥情節的具體藥物名稱。請讀者切莫效仿。若您在閱讀中感到不適，或出現其他可能導致危險的精神體驗，請立即停止閱讀並尋求專業醫生或社群的幫助。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"序章\"),\"\\n\",Vue.h(_components.p,null,\"彩加與我尚在重慶的時候，我和她常去樓下的飯店吃豆花飯。老闆娘同我熟絡，每回去了都認得我。\"),\"\\n\",Vue.h(_components.p,null,\"川渝的豆花飯，食必佐以辛辣，豆花本身倒無甚滋味。\"),\"\\n\",Vue.h(_components.p,null,\"燒椒醬味辛，入口皆辣；若換了旁的調料，又是旁的味道。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"彩加，一個小孩子。\"),\"\\n\",Vue.h(_components.p,null,\"……在我看來，就像豆花一樣吧。\"),\"\\n\",Vue.h(_components.p,null,\"豆花本無味，所佐何味，便染何味。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"歲初，得還渝北故地。老闆娘猶在，笑迎如舊。然而故人已去，再無那個她與我同吃一碗豆花飯了。\"),\"\\n\",Vue.h(_components.h2,null,\"初識\"),\"\\n\",Vue.h(_components.p,null,\"彩加，一個小孩子。24 年初的時候，我也只是因為她做藥代而認識的她。當時，她是怎樣吸引到我的呢……？\"),\"\\n\",Vue.h(_components.p,null,\"那會兒，我的頭像是《黑暗靈魂》中的葛溫德林，當她問到我的頭像是否出自黑魂時，我回答說是，那種找到同好的喜悅感便湧上心頭。也不知道是出於何種心理，我傾聽了很多她訴說的故事，於是心生憐憫，或許也是因為自己的孤獨寂寞，我和她以姐妹互稱，關係也愈加親密，她也就用了葛溫德林的妹妹幽兒希卡當 QQ 頭像。\"),\"\\n\",Vue.h(_components.p,null,\"她很喜歡聽 VOCALOID 的曲子，總帶著我聽各種 V 家曲。還喜歡魔圓的片頭曲《\",Vue.h(\"ruby\",null,\"コネクト\",Vue.h(\"rt\",null,\"Connect\")),\"》。她真的很喜歡小圓呢，在她的認知裡，所有人死去之後都會被圓環之理所接引\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-1\",id:\"footnote-ref-1\"},\"1\")),\"。\"),\"\\n\",Vue.h(_components.p,null,\"當彩加還在湖南的那會兒，我給她點過奶茶，也正是因此而記下了她家的地址。有一回，我聽到她嘗試自殺的消息，情急之下把地址報給了當地的警察。直到警察回覆我說，她已經當面把吞下去的藥吐出來了，我這才放心些。\"),\"\\n\",Vue.h(_components.h2,null,\"相遇\"),\"\\n\",Vue.h(_components.p,null,\"認識了一段時間之後，我讓彩加從湖南來重慶同我一起住。彩加真的是個小孩子啊，我或許是把她「騙」到家裡來的。\"),\"\\n\",Vue.h(_components.p,null,\"彩加說，要來我家的話，沒問題。可我不准阻止她割手，不准阻止她 OD，也不准——阻止她援交，我也只能點點頭默許了，雖然最後她也沒去。\"),\"\\n\",Vue.h(_components.p,null,\"3 月 13 日，彩加坐高鐵來找我，票卻買到偏遠的重慶西站去了。但我還是早早地坐輕軌跑到重慶西站等著。好不容易到站了，這個小路癡又迷了路，我們倆互相尋了半天才碰上面。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo1.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（相遇時的牽手，上面的是我的手，下面的是彩加的手。）\"),\"\\n\",Vue.h(_components.p,null,\"看到她的第一眼，我的內心就感覺，「啊，那一定就是命中註定的緣分」，之後就牽著她的手，坐輕軌回家了。\"),\"\\n\",Vue.h(_components.h2,null,\"薄荷\"),\"\\n\",Vue.h(_components.p,null,\"憑藉著她作為藥代的身份，我們經常買藥一起吃，但我卻沒有意識到這其實只是短暫的快樂。\"),\"\\n\",Vue.h(_components.p,null,\"記得她見我之前，一直很好奇氯硝西泮是什麼味道。我說，是薄荷味的，還可以舌下含服當糖吃。\"),\"\\n\",Vue.h(_components.p,null,\"來我這邊住的第一天晚上，或許是因為認床，不太習慣。她一直翻來覆去的，我便倒出一粒氯硝西泮含到嘴裡，然後湊近親上去餵給她。\"),\"\\n\",Vue.h(_components.p,null,\"她好像有點驚訝，沒想到我會這麼做，等她回過味來，原來真的是薄荷一樣的味道。\"),\"\\n\",Vue.h(_components.h2,null,\"左右\"),\"\\n\",Vue.h(_components.p,null,\"她的情緒很不穩定。一崩潰就衝進衛生間鎖上門，用手術刀割手割大腿。有時只是我倆意見不合，她也會把自己鎖起來自傷。我毫無辦法，也因此極度崩潰，卻無處宣洩，只能學著她的樣子傷害自己。迄今我左手上的留下的傷痕還清晰可見。\"),\"\\n\",Vue.h(_components.p,null,\"有一次吵架，我還因為她割手和她搶刀扭打起來了。她要去跳樓，我給她拉住了。但是我力氣沒她大，我看這樣不行，只好報了警，希望能讓她消停下來。當晚，彩加被送到了重慶渝北區精衛，她在那裡住了一晚上。\"),\"\\n\",Vue.h(_components.p,null,\"第二天我去看她，卻被告知不是家屬不能進去探視，我就在外面等啊等，等她家裡人來。直到傍晚，她的祖父和父親來了，我和他們見了面，他們進去和醫生聊了聊，彩加就被放出來了。她的家人和我說，還是希望我把彩加照顧好，也叮囑彩加不要鬧事。他們在重慶待了一天就回去了，其實看起來人還挺好的。\"),\"\\n\",Vue.h(_components.p,null,\"我和彩加一起的時候，也曾設想過未來的事情。我和她說，要一起學好日語，將來要去日本，還和她母親聊到了這個計畫，認真地制定了一套方案。她母親待她倒是不錯，我從中調和了一陣之後，她母親就接受了她的性別認同，還給她買女孩子的衣服，是個溫和的人。\"),\"\\n\",Vue.h(_components.h2,null,\"陪伴\"),\"\\n\",Vue.h(_components.p,null,\"如今仔細算來，我在重慶陪她的日子或許也只有兩個月不到。但她確是度過了一段很愉快的時光。\"),\"\\n\",Vue.h(_components.p,null,\"她很喜歡吃脆香米乾脆麵、番茄方便麵，還有不二家的棒棒糖，每次去便利店都要買一堆，然後抱在懷裡帶回家。還喜歡和我一起吃麥當當，在麥當當裡邊炫板烤雞腿堡和冰炫風。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo2.webp\",\"${path}/photos/photo3.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（與她在麥當勞餐廳）\"),\"\\n\",Vue.h(_components.p,null,\"彩加很喜歡看動畫，那會兒我和她一起看完了《夢想成為魔法少女》。番劇名字聽著像魔法少女的故事，實際上卻滿溢著奇怪的百合成分。她最喜歡的角色是小琪舞，那是個表面上看起來像笨蛋，實際隱藏自己許多實力的傢伙呢。有時候吃完了藥，我們便躺在沙發上，把電腦接到電視上接著享受動畫的內容。\"),\"\\n\",Vue.h(_components.p,null,\"我們有時買來 Rio 微醺酒，一起看《假面騎士 Build》。她還挺喜歡這個的，她印象最深的場面是猿渡一海的最後一次變身，因為那一次的「危險等級\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-2\",id:\"footnote-ref-2\"},\"2\")),\"」太高，他為了拯救同伴，拯救世界而使用暴雪拳套強行變身，最後因為超出人類的承受能力死掉了。\"),\"\\n\",Vue.h(_components.p,null,\"閒下來的時間裡，我們也會在一起打遊戲。她非常喜歡黑魂系列和它的同人作 BLACK SOULS。我和她一起玩過《黑暗靈魂 1》。畢竟也是因為頭像而相識的。我其實老早就入坑黑魂了，畢竟老手嘛。有時候，她有打不過的 BOSS，我就乾脆利落地坐到電腦桌前：「我來！沒有你姐姐打不過的！」\"),\"\\n\",Vue.h(_components.p,null,\"我們去過許多地方，那些都是值得高興的回憶。在觀音橋\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-3\",id:\"footnote-ref-3\"},\"3\")),\"，解放碑步行街\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-4\",id:\"footnote-ref-4\"},\"4\")),\"……好多地方一起玩。那是我很久沒有感受到的快樂，好像自己不那麼孤獨了。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo4.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（在解放碑步行街附近同她拍攝的大頭貼）\"),\"\\n\",Vue.h(_components.p,null,\"想起來和她一起走在解放碑的街道上，在晚上八九點鐘左右的解放碑步行街上走著，只是和她牽著手，卻感覺好像有了整個世界。\"),\"\\n\",Vue.h(_components.p,null,\"想起來明明還是未成年，那會兒卻偷偷跑去酒吧點了杯酒。我記得是藍色瑪格麗特\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-5\",id:\"footnote-ref-5\"},\"5\")),\"吧，那是我在酒吧喝的第一杯酒，也是她的第一杯酒。\"),\"\\n\",Vue.h(_components.p,null,\"想起來有一次一起出去吃飯，是在重慶中央公園\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-6\",id:\"footnote-ref-6\"},\"6\")),\"的商圈那邊。大概是宅在家裡太久了吧，想要出去吃點好的。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"「這次我們去哪兒玩呀？解放碑？還是中央公園呢？」\"),\"\\n\",Vue.h(_components.p,null,\"「那就去更近些的中央公園吧。」\"),\"\\n\",Vue.h(_components.p,null,\"「聽你的~」\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"公園天街樓下有一家很大的手辦店，我和彩加在裡邊轉悠了很久，那麼多可愛的手辦，都想要，卻都買不起。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo5.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（天街埠口西餐吧的約會）\"),\"\\n\",Vue.h(_components.p,null,\"於是我們到樓上的埠口西餐吧坐下來吃東西，是很豐盛的一餐呢，彩加很開心。不過或許女孩子真的有四個胃吧，一個胃用來裝正餐，一個胃用來裝零食，一個胃用來吃水果，還有一個胃用來喝飲料。吃完正餐之後，我們又從天街商場出來，尋覓餐後消遣的飲品。\"),\"\\n\",Vue.h(_components.p,null,\"到了奈雪，我和彩加點了單坐下等待，直到店員呼叫我們的訂單編號。碰巧就在這時，她的母親打電話過來問彩加的近況，於是就有了這張照片：\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo6.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（彩加於天街奈雪前的留影）\"),\"\\n\",Vue.h(_components.p,null,\"說起來，之前聽說附近的遊戲廳裡有 maimai 的機子，但畢竟我和彩加都是社恐，也就一次也沒有碰過。\"),\"\\n\",Vue.h(_components.h2,null,\"玩偶\"),\"\\n\",Vue.h(_components.p,null,\"4 月 29 日是我的生日，彩加早早地給我準備了一個玩偶。是一條……大鯊魚。\"),\"\\n\",Vue.h(_components.p,null,\"結果彩加這孩子有些笨手笨腳，拆快遞的時候一刀下去，竟然一不小心把裡面的鯊鯊給捅死了。\"),\"\\n\",Vue.h(_components.p,null,\"彩加有些不開心。\"),\"\\n\",Vue.h(_components.p,null,\"「沒事的，會好起來的。」我安慰她。\"),\"\\n\",Vue.h(_components.p,null,\"趁她轉身回到房間裡去的工夫，我翻出母親留下的針線盒，按照網上的教程，又把鯊鯊給縫了回去。\"),\"\\n\",Vue.h(_components.p,null,\"「你看你看，它又復活了哦！」\"),\"\\n\",Vue.h(_components.p,null,\"但彩加還是很愧疚，覺得是自己不好，把送我的生日禮物給弄壞了。再後來，作為補償，她又給我買了一隻庫洛米玩偶。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo7.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（彩加贈我的庫洛米玩偶）\"),\"\\n\",Vue.h(_components.p,null,\"雖然鯊鯊現在已經不在我身邊了，但那隻庫洛米玩偶，我至今仍一直帶在身邊。\"),\"\\n\",Vue.h(_components.h2,null,\"群蟲\"),\"\\n\",Vue.h(_components.p,null,\"她一直聽信著 OD 圈裡某位「醫師」的話，聽說什麼金剛烷胺好吃，就經常背著我買金剛烷胺來吃，結果把自己精神弄得很差。說經常看到幻覺，看到蟲子，我也不知道該怎麼辦。只能把她的藥給丟了，然後陪著她。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我真的挺怕蟲子……\"),\"\\n\",Vue.h(_components.p,null,\"晚安\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-7\",id:\"footnote-ref-7\"},\"7\")),\"的幻覺真的特別的怪，嚇人。\"),\"\\n\",Vue.h(_components.p,null,\"床底湧出的群蟲，眼鏡玻璃碎裂一地的地面……\"),\"\\n\",Vue.h(_components.p,null,\"晚安，真的諷刺……\"),\"\\n\",Vue.h(_components.p,null,\"（節選自彩加的推文）\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"再到後來有一次……好像是因為我不想她再拿手術刀自傷了，和她扭打了起來。她把我打得鼻青臉腫，我很崩潰，想要到房間裡靜一靜。她以為我要幹什麼傻事，直接就把我的房間門鎖給弄壞了，然後衝撞過來。\"),\"\\n\",Vue.h(_components.p,null,\"這事被我們雙方家裡人知道了，於是他們要求彩加回到湖南去。可是我看著她那樣又捨不得，彩加也覺得自己做錯了也捨不得我。於是我們一起編了個謊言，就說彩加去別的地方找朋友玩了，實際上仍然她留在了我這裡。\"),\"\\n\",Vue.h(_components.h2,null,\"長夜\"),\"\\n\",Vue.h(_components.p,null,\"5 月 4 日那天，渝北下了小雨，我玩遊戲玩了個通宵。\"),\"\\n\",Vue.h(_components.p,null,\"彩加湊近問我：「最近姐姐都沒有 OD 了，怎麼啦……？」\"),\"\\n\",Vue.h(_components.p,null,\"想來也許是覺得她狀態太糟，無意識中覺得，是不是別再碰了比較好，現時已然記不清了。可她又主動提了，我心想，這樣啊，還是順從她的意願吧。\"),\"\\n\",Vue.h(_components.p,null,\"「好像是誒，你要吃的話，我陪你去買點。」我說道。\"),\"\\n\",Vue.h(_components.p,null,\"買藥回家的路上，她又去拿了份包裹，是一盒空膠囊殼子。按她的說法，把藥弄碎了放進去就不難吃了，後來我和她一起吃了。\"),\"\\n\",Vue.h(_components.p,null,\"……我當時究竟在搞什麼……\"),\"\\n\",Vue.h(_components.p,null,\"結果是自己又好像覺得睡不著，又吃了氯硝西泮想要躺到床上去了。可也就是在那前後，她的手機和身分證不見了。\"),\"\\n\",Vue.h(_components.p,null,\"「這個之後慢慢找，我好累好睏……先睡一下吧。」\"),\"\\n\",Vue.h(_components.p,null,\"可能是因為氯硝西泮的後勁太大，我再度醒來的時候，已經是在救護車上了。彩加就湊到我眼前和我說，她怎麼喊都喊不醒我，便用我的手機打了 120。\"),\"\\n\",Vue.h(_components.p,null,\"「啥情況……我這不是清醒著嗎，就是有點睏……」因為沒什麼大礙，於是我結了救護車的費用，就同彩加回家繼續休息了。\"),\"\\n\",Vue.h(_components.p,null,\"再醒來已是凌晨三四點，我發現手機不見了。通過 iCloud 的查找功能，發現定位在派出所。我披上衣服趕過去，果然在那邊找到了她。\"),\"\\n\",Vue.h(_components.p,null,\"她穿著一身我沒見過的衣服。後來才知道，是因為她只穿著上半身的衣服在外面跑，被人逮到派出所去了。\"),\"\\n\",Vue.h(_components.p,null,\"「妹，你怎麼跑派出所來了？不回家嗎，我們回家睡覺去呀！」我腦袋本也有點昏昏沉沉的。\"),\"\\n\",Vue.h(_components.p,null,\"然後我就把手機拿回來，牽著彩加的手回去了。\"),\"\\n\",Vue.h(_components.h2,null,\"夢碎\"),\"\\n\",Vue.h(_components.p,null,\"「我還想玩遊戲，姐姐還能玩黑魂嗎？」彩加回到家之後問我。\"),\"\\n\",Vue.h(_components.p,null,\"因為一直發生著許多事情，我還是感到好睏好想休息，於是只能先安撫了下她，然後關燈睡了。\"),\"\\n\",Vue.h(\"details\",null,Vue.h(\"summary\",null,\"這回再次醒來，已是早上 6 點左右了。物業的人急匆匆地來敲我家的門，卻並沒有告訴我出了什麼事。只說讓我趕緊下樓。\"),Vue.h(_components.p,null,\"我在恍惚中下了樓。幾個像是保安，抑或是警察的人領著我往前走。\"),Vue.h(_components.p,null,\"「怎麼了這是……大清早的。我妹呢？」\"),Vue.h(_components.p,null,\"直到我走到了物業前的那片運動場地，角落中有一具凝滯的身形。\"),Vue.h(_components.p,null,\"我有些懵。這是什麼……？這是誰……？\"),Vue.h(_components.p,null,\"那具身形背對著我，我仔細看了看她身上僅有的上衣，突然從朦朧中驚醒。\"),Vue.h(_components.p,null,\"「妹！你怎麼了！妹！回答我啊！回應我一下吧……」我不斷地呼喊著她，希望她能有點反應。\"),Vue.h(_components.p,null,\"但沒有任何回應。\"),Vue.h(_components.p,null,\"圍在她附近的保安也不讓我靠近她。\"),Vue.h(_components.p,null,\"「哎，人已經走啦。剛剛救護車都來過了，看了下就走了。已經沒有搶救的必要了。」旁邊的阿姨嘆了口氣，然後轉過身去，不願再理會我。\"),Vue.h(_components.p,null,\"警察也催著我走，好像是要我去做些什麼，喊我別看了。\"),Vue.h(_components.p,null,\"可我還是捨不得，我的雙腿就像灌了鉛，好沉重，駐足在原地。\"),Vue.h(_components.p,null,\"他們走上前去，把彩加翻了個面。我才終於看清了她的臉龐。\")),\"\\n\",Vue.h(_components.p,null,\"淚水止不住地流下。\"),\"\\n\",Vue.h(_components.p,null,\"「對不起……姐姐沒有保護好你……」\"),\"\\n\",Vue.h(_components.h2,null,\"缺失\"),\"\\n\",Vue.h(_components.p,null,\"做完筆錄之後，派出所的人怕我情緒崩潰，一個人在重慶受不了直接尋死。於是我在裡頭被關了兩天，直到我的母親從新疆趕回重慶，才把我從派出所領出來。\"),\"\\n\",Vue.h(_components.p,null,\"「吃過飯了嗎？」\"),\"\\n\",Vue.h(_components.p,null,\"「我什麼都不想吃，也完全沒有心情吃……」\"),\"\\n\",Vue.h(_components.p,null,\"說是這麼說，但後來，我還是去了樓下的那家麥當勞買了麥旋風吃。\"),\"\\n\",Vue.h(_components.p,null,\"「彩加……愛吃這個。」\"),\"\\n\",Vue.h(_components.p,null,\"「別提這些了。」\"),\"\\n\",Vue.h(_components.p,null,\"再往回家的路走，我有意地走到那個運動場地的小角落。那裡好像被打掃乾淨了，完全看不出這裡昨天一早到底發生了什麼。\"),\"\\n\",Vue.h(_components.p,null,\"一條生命，拉上警戒線，用罩子蓋住，驅散人群，不一會兒，就好像這件事情從來沒發生過一樣。\"),\"\\n\",Vue.h(_components.p,null,\"那些目擊了這場慘劇的人，又怎麼會把這件事放在心上呢？他們很快便各自散去。\"),\"\\n\",Vue.h(_components.p,null,\"人群照舊來去匆匆，笑聲與腳步聲交錯不息。到最後唯有我一人記得，這片大人小孩嬉戲的角落曾發生過什麼。\"),\"\\n\",Vue.h(_components.h2,null,\"渝北\"),\"\\n\",Vue.h(_components.p,null,\"彩加走的時候還留下了兩包沒吃完的番茄方便麵。\"),\"\\n\",Vue.h(_components.p,null,\"因為發生了這樣的事情，我被家裡人帶走軟禁起來了。後來，由於家庭原因，我徹底離開了重慶。\"),\"\\n\",Vue.h(_components.p,null,\"渝北的那個家是我回不去的家，承載著我的青春，也承載著我最痛苦的事。\"),\"\\n\",Vue.h(_components.p,null,\"三月，回到渝北舊居。給她帶了幾瓶複方甘草片。\"),\"\\n\",Vue.h(_components.p,null,\"懷念從前拿著預調酒兌可樂，吃甘草片和右美的日子。還有那條去取包裹的小路。\"),\"\\n\",Vue.h(_components.p,null,\"她會記得這些嗎？在不知何處，她有得到幸福嗎……？\"),\"\\n\",Vue.h(_components.p,null,\"轉眼間渝北之名也漸隨風飄散，屬於渝北的各種牌子被一塊一塊地摘下，取而代之的是兩江新區\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-8\",id:\"footnote-ref-8\"},\"8\")),\"。\"),\"\\n\",Vue.h(_components.p,null,\"那段故事卻永遠留在了再也回不去的渝北。\"),\"\\n\",Vue.h(_components.h2,null,\"終章\"),\"\\n\",Vue.h(_components.p,null,\"OD 圈對彩加的影響太大了，如果不是那樣，她或許會有一個不錯的未來。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"彩加，一個小孩子。\"),\"\\n\",Vue.h(_components.p,null,\"……在我看來，就像豆花一樣吧。\"),\"\\n\",Vue.h(_components.p,null,\"和什麼人在一起，就會變成什麼樣子……\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"彩加走後，我在酒吧再沒點過別的酒。只喝藍色瑪格麗特。每次去酒吧我都只點這個。雖然我其實一點也不喜歡喝這種……它的杯口沾著海鹽，又苦又澀。\"),\"\\n\",Vue.h(_components.p,null,\"但那是我在酒吧喝的第一杯酒，也是她的第一杯酒。\"),\"\\n\",Vue.h(_components.p,null,\"條目貢獻：\",Vue.h(_components.a,{href:\"https://twitter.com/Poetry_Luna\"},\"櫻崎詩月\")),\"\\n\",Vue.h(\"ol\",null,Vue.h(\"li\",{id:\"footnote-1\"},\"詳見《魔法少女小圓》電視動畫最終話《わたしの、最高の友達》。\",Vue.h(\"a\",{href:\"#footnote-ref-1\"},Vue.h(\"svg\",{viewBox:\"0 0 16 16\",version:\"1.1\",id:\"svg1\",\"xmlns:xlink\":\"http://www.w3.org/1999/xlink\",xmlns:\"http://www.w3.org/2000/svg\",\"xmlns:svg\":\"http://www.w3.org/2000/svg\",style:\"margin-left: 0.5rem; margin-bottom: -2px; width: 1rem; height: 1rem\"},Vue.