"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({a:\"a\",blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components),PhotoScroll=_components.PhotoScroll,Sakura=_components.Sakura;if(!PhotoScroll)_missingMdxReference(\"PhotoScroll\",true);if(!Sakura)_missingMdxReference(\"Sakura\",true);return Vue.h(Vue.Fragment,null,Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,Vue.h(\"svg\",{style:\"display: inline-block; overflow: visible !important; vertical-align: sub; fill: rgb(26, 127, 55); margin-right: 10px;\",viewBox:\"0 0 16 16\",version:\"1.1\",width:\"16\",height:\"16\",\"aria-hidden\":\"true\"},Vue.h(\"path\",{d:\"M8 1.5c-2.363 0-4 1.69-4 3.75 0 .984.424 1.625.984 2.304l.214.253c.223.264.47.556.673.848.284.411.537.896.621 1.49a.75.75 0 0 1-1.484.211c-.04-.282-.163-.547-.37-.847a8.456 8.456 0 0 0-.542-.68c-.084-.1-.173-.205-.268-.32C3.201 7.75 2.5 6.766 2.5 5.25 2.5 2.31 4.863 0 8 0s5.5 2.31 5.5 5.25c0 1.516-.701 2.5-1.328 3.259-.095.115-.184.22-.268.319-.207.245-.383.453-.541.681-.208.3-.33.565-.37.847a.751.751 0 0 1-1.485-.212c.084-.593.337-1.078.621-1.489.203-.292.45-.584.673-.848.075-.088.147-.173.213-.253.561-.679.985-1.32.985-2.304 0-2.06-1.637-3.75-4-3.75ZM5.75 12h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1 0-1.5ZM6 15.25a.75.75 0 0 1 .75-.75h2.5a.75.75 0 0 1 0 1.5h-2.5a.75.75 0 0 1-.75-.75Z\"})),\" 阅读提示：本文因叙事完整性与连贯性的需要，破例保留了部分涉及药物滥用与敏感用药情节的具体药物名称。请读者切莫效仿。若您在阅读中感到不适，或出现其他可能导致危险的精神体验，请立即停止阅读并寻求专业医生或社群的帮助。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"序章\"),\"\\n\",Vue.h(_components.p,null,\"彩加与我尚在重庆的时候，我和她常去楼下的饭店吃豆花饭。老板娘同我熟络，每回去了都认得我。\"),\"\\n\",Vue.h(_components.p,null,\"川渝的豆花饭，食必佐以辛辣，豆花本身倒无甚滋味。\"),\"\\n\",Vue.h(_components.p,null,\"烧椒酱味辛，入口皆辣；若换了旁的调料，又是旁的味道。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"彩加，一个小孩子。\"),\"\\n\",Vue.h(_components.p,null,\"……在我看来，就像豆花一样吧。\"),\"\\n\",Vue.h(_components.p,null,\"豆花本无味，所佐何味，便染何味。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"岁初，得还渝北故地。老板娘犹在，笑迎如旧。然而故人已去，再无那个她与我同吃一碗豆花饭了。\"),\"\\n\",Vue.h(_components.h2,null,\"初识\"),\"\\n\",Vue.h(_components.p,null,\"彩加，一个小孩子。24 年初的时候，我也只是因为她做药代而认识的她。当时，她是怎样吸引到我的呢……？\"),\"\\n\",Vue.h(_components.p,null,\"那会儿，我的头像是《黑暗之魂》中的葛温德林，当她问到我的头像是否出自黑魂时，我回答说是，那种找到同好的喜悦感便涌上心头。也不知道是出于何种心理，我倾听了很多她诉说的故事，于是心生怜悯，或许也是因为自己的孤独寂寞，我和她以姐妹互称，关系也愈加亲密，她也就用了葛温德林的妹妹幽儿希卡当 QQ 头像。\"),\"\\n\",Vue.h(_components.p,null,\"她很喜欢听 VOCALOID 的曲子，总带着我听各种术曲。还喜欢魔圆的片头曲《\",Vue.h(\"ruby\",null,\"コネクト\",Vue.h(\"rt\",null,\"Connect\")),\"》。她真的很喜欢小圆呢，在她的认知里，所有人死去之后都会被圆环之理所接引\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-1\",id:\"footnote-ref-1\"},\"1\")),\"。\"),\"\\n\",Vue.h(_components.p,null,\"当彩加还在湖南的那会儿，我给她点过奶茶，也正是因此而记下了她家的地址。有一回，我听到她尝试自杀的消息，情急之下把地址报给了当地的警察。直到警察回复我说，她已经当面把吞下去的药吐出来了，我这才放心些。\"),\"\\n\",Vue.h(_components.h2,null,\"相遇\"),\"\\n\",Vue.h(_components.p,null,\"认识了一段时间之后，我让彩加从湖南来重庆同我一起住。彩加真的是个小孩子啊，我或许是把她「骗」到家里来的。\"),\"\\n\",Vue.h(_components.p,null,\"彩加说，要来我家的话，没问题。可我不准阻止她割手，不准阻止她 OD，也不准——阻止她援交，我也只能点点头默许了，虽然最后她也没去。\"),\"\\n\",Vue.h(_components.p,null,\"3 月 13 日，彩加坐高铁来找我，票却买到偏远的重庆西站去了。但我还是早早地坐轻轨跑到重庆西站等着。好不容易到站了，这个小路痴又迷了路，我们俩互相寻了半天才碰上面。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo1.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（相遇时的牵手，上面的是我的手，下面的是彩加的手。）\"),\"\\n\",Vue.h(_components.p,null,\"看到她的第一眼，我的内心就感觉，「啊，那一定就是命中注定的缘分」，之后就牵着她的手，坐轻轨回家了。\"),\"\\n\",Vue.h(_components.h2,null,\"薄荷\"),\"\\n\",Vue.h(_components.p,null,\"凭借着她作为药代的身份，我们经常买药一起吃，但我却没有意识到这其实只是短暂的快乐。\"),\"\\n\",Vue.h(_components.p,null,\"记得她见我之前，一直很好奇氯硝西泮是什么味道。我说，是薄荷味的，还可以舌下含服当糖吃。\"),\"\\n\",Vue.h(_components.p,null,\"来我这边住的第一天晚上，或许是因为认床，不太习惯。她一直翻来覆去的，我便倒出一粒氯硝西泮含到嘴里，然后凑近亲上去喂给她。\"),\"\\n\",Vue.h(_components.p,null,\"她好像有点惊讶，没想到我会这么做，等她回过味来，原来真的是薄荷一样的味道。\"),\"\\n\",Vue.h(_components.h2,null,\"左右\"),\"\\n\",Vue.h(_components.p,null,\"她的情绪很不稳定。一崩溃就冲进卫生间锁上门，用手术刀割手割大腿。有时只是我俩意见不合，她也会把自己锁起来自伤。我毫无办法，也因此极度崩溃，却无处宣泄，只能学着她的样子伤害自己。迄今我左手上的留下的伤痕还清晰可见。\"),\"\\n\",Vue.h(_components.p,null,\"有一次吵架，我还因为她割手和她抢刀扭打起来了。她要去跳楼，我给她拉住了。但是我力气没她大，我看这样不行，只好报了警，希望能让她消停下来。当晚，彩加被送到了重庆渝北区精卫，她在那里住了一晚上。\"),\"\\n\",Vue.h(_components.p,null,\"第二天我去看她，却被告知不是家属不能进去探视，我就在外面等啊等，等她家里人来。直到傍晚，她的祖父和父亲来了，我和他们见了面，他们进去和医生聊了聊，彩加就被放出来了。她的家人和我说，还是希望我把彩加照顾好，也叮嘱彩加不要闹事。他们在重庆待了一天就回去了，其实看起来人还挺好的。\"),\"\\n\",Vue.h(_components.p,null,\"我和彩加一起的时候，也曾设想过未来的事情。我和她说，要一起学好日语，将来要去日本，还和她母亲聊到了这个计划，认真地制定了一套方案。她母亲待她倒是不错，我从中调和了一阵之后，她母亲就接受了她的性别认同，还给她买女孩子的衣服，是个温和的人。\"),\"\\n\",Vue.h(_components.h2,null,\"陪伴\"),\"\\n\",Vue.h(_components.p,null,\"如今仔细算来，我在重庆陪她的日子或许也只有两个月不到。但她确是度过了一段很愉快的时光。\"),\"\\n\",Vue.h(_components.p,null,\"她很喜欢吃脆香米干脆面、番茄方便面，还有不二家的棒棒糖，每次去便利店都要买一堆，然后抱在怀里带回家。还喜欢和我一起吃麦麦，在麦麦里边炫板烧鸡腿堡和麦旋风。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo2.webp\",\"${path}/photos/photo3.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（与她在麦当劳餐厅）\"),\"\\n\",Vue.h(_components.p,null,\"彩加很喜欢看动画，那会儿我和她一起看完了《憧憬成为魔法少女》。番剧名字听着像魔法少女的故事，实际上却满溢着奇怪的百合成分。她最喜欢的角色是小琪舞，那是个表面上看起来像笨蛋，实际隐藏自己许多实力的家伙呢。有时候吃完了药，我们便躺在沙发上，把电脑接到电视上接着享受动画的内容。\"),\"\\n\",Vue.h(_components.p,null,\"我们有时买来 Rio 微醺酒，一起看《假面骑士 Build》。她还挺喜欢这个的，她印象最深的场面是猿渡一海的最后一次变身，因为那一次的「危险等级\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-2\",id:\"footnote-ref-2\"},\"2\")),\"」太高，他为了拯救同伴，拯救世界而使用暴雪拳套强行变身，最后因为超出人类的承受能力死掉了。\"),\"\\n\",Vue.h(_components.p,null,\"闲下来的时间里，我们也会在一起打游戏。她非常喜欢黑魂系列和它的同人作 BLACK SOULS。我和她一起玩过《黑暗之魂 1》。毕竟也是因为头像而相识的。我其实老早就入坑黑魂了，毕竟老手嘛。有时候，她有打不过的 BOSS，我就干脆利落地坐到电脑桌前：「我来！没有你姐姐打不过的！」\"),\"\\n\",Vue.h(_components.p,null,\"我们去过许多地方，那些都是值得高兴的回忆。在观音桥\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-3\",id:\"footnote-ref-3\"},\"3\")),\"，解放碑步行街\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-4\",id:\"footnote-ref-4\"},\"4\")),\"……好多地方一起玩。那是我很久没有感受到的快乐，好像自己不那么孤独了。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo4.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（在解放碑步行街附近同她拍摄的大头贴）\"),\"\\n\",Vue.h(_components.p,null,\"想起来和她一起走在解放碑的街道上，在晚上八九点钟左右的解放碑步行街上走着，只是和她牵着手，却感觉好像有了整个世界。\"),\"\\n\",Vue.h(_components.p,null,\"想起来明明还是未成年，那会儿却偷偷跑去酒吧点了杯酒。我记得是蓝色玛格丽特\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-5\",id:\"footnote-ref-5\"},\"5\")),\"吧，那是我在酒吧喝的第一杯酒，也是她的第一杯酒。\"),\"\\n\",Vue.h(_components.p,null,\"想起来有一次一起出去吃饭，是在重庆中央公园\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-6\",id:\"footnote-ref-6\"},\"6\")),\"的商圈那边。大概是宅在家里太久了吧，想要出去吃点好的。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"「这次我们去哪儿玩呀？解放碑？还是中央公园呢？」\"),\"\\n\",Vue.h(_components.p,null,\"「那就去更近些的中央公园吧。」\"),\"\\n\",Vue.h(_components.p,null,\"「听你的~」\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"公园天街楼下有一家很大的手办店，我和彩加在里边转悠了很久，那么多可爱的手办，都想要，却都买不起。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo5.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（天街埠口西餐吧的约会）\"),\"\\n\",Vue.h(_components.p,null,\"于是我们到楼上的埠口西餐吧坐下来吃东西，是很丰盛的一餐呢，彩加很开心。不过或许女孩子真的有四个胃吧，一个胃用来装正餐，一个胃用来装零食，一个胃用来吃水果，还有一个胃用来喝饮料。吃完正餐之后，我们又从天街商场出来，寻觅餐后消遣的饮品。\"),\"\\n\",Vue.h(_components.p,null,\"到了奈雪，我和彩加点了单坐下等待，直到店员呼叫我们的订单编号。碰巧就在这时，她的母亲打电话过来问彩加的近况，于是就有了这张照片：\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo6.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（彩加于天街奈雪前的留影）\"),\"\\n\",Vue.h(_components.p,null,\"说起来，之前听说附近的游戏厅里有舞萌的机子，但毕竟我和彩加都是社恐，也就一次也没有碰过。\"),\"\\n\",Vue.h(_components.h2,null,\"玩偶\"),\"\\n\",Vue.h(_components.p,null,\"4 月 29 日是我的生日，彩加早早地给我准备了一个玩偶。是一条……大鲨鱼。\"),\"\\n\",Vue.h(_components.p,null,\"结果彩加这孩子有些笨手笨脚，拆快递的时候一刀下去，竟然一不小心把里面的鲨鲨给捅死了。\"),\"\\n\",Vue.h(_components.p,null,\"彩加有些不开心。\"),\"\\n\",Vue.h(_components.p,null,\"「没事的，会好起来的。」我安慰她。\"),\"\\n\",Vue.h(_components.p,null,\"趁她转身回到房间里去的工夫，我翻出母亲留下的针线盒，按照网上的教程，又把鲨鲨给缝了回去。\"),\"\\n\",Vue.h(_components.p,null,\"「你看你看，它又复活了哦！」\"),\"\\n\",Vue.h(_components.p,null,\"但彩加还是很愧疚，觉得是自己不好，把送我的生日礼物给弄坏了。再后来，作为补偿，她又给我买了一只库洛米玩偶。\"),\"\\n\",Vue.h(PhotoScroll,{photos:[\"${path}/photos/photo7.webp\"]}),\"\\n\",Vue.h(\"p\",{style:\"text-align: center;\"},\"（彩加赠我的库洛米玩偶）\"),\"\\n\",Vue.h(_components.p,null,\"虽然鲨鲨现在已经不在我身边了，但那只库洛米玩偶，我至今仍一直带在身边。\"),\"\\n\",Vue.h(_components.h2,null,\"群虫\"),\"\\n\",Vue.h(_components.p,null,\"她一直听信着 OD 圈里某位「医师」的话，听说什么金刚烷胺好吃，就经常背着我买金刚烷胺来吃，结果把自己精神弄得很差。说经常看到幻觉，看到虫子，我也不知道该怎么办。只能把她的药给丢了，然后陪着她。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我真的挺怕虫子……\"),\"\\n\",Vue.h(_components.p,null,\"晚安\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-7\",id:\"footnote-ref-7\"},\"7\")),\"的幻觉真的特别的怪，吓人。\"),\"\\n\",Vue.h(_components.p,null,\"床底涌出的群虫，眼镜玻璃碎裂一地的地面……\"),\"\\n\",Vue.h(_components.p,null,\"晚安，真的讽刺……\"),\"\\n\",Vue.h(_components.p,null,\"（节选自彩加的推文）\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"再到后来有一次……好像是因为我不想她再拿手术刀自伤了，和她扭打了起来。她把我打得鼻青脸肿，我很崩溃，想要到房间里静一静。她以为我要干什么傻事，直接就把我的房间门锁给弄坏了，然后冲撞过来。\"),\"\\n\",Vue.h(_components.p,null,\"这事被我们双方家里人知道了，于是他们要求彩加回到湖南去。可是我看着她那样又舍不得，彩加也觉得自己做错了也舍不得我。于是我们一起编了个谎言，就说彩加去别的地方找朋友玩了，实际上仍然她留在了我这里。\"),\"\\n\",Vue.h(_components.h2,null,\"长夜\"),\"\\n\",Vue.h(_components.p,null,\"5 月 4 日那天，渝北下了小雨，我玩游戏玩了个通宵。\"),\"\\n\",Vue.h(_components.p,null,\"彩加凑近问我：「最近姐姐都没有 OD 了，怎么啦……？」\"),\"\\n\",Vue.h(_components.p,null,\"想来也许是觉得她状态太糟，无意识中觉得，是不是别再碰了比较好，现时已然记不清了。可她又主动提了，我心想，这样啊，还是顺从她的意愿吧。\"),\"\\n\",Vue.h(_components.p,null,\"「好像是诶，你要吃的话，我陪你去买点。」我说道。\"),\"\\n\",Vue.h(_components.p,null,\"买药回家的路上，她又去拿了份快递，是一盒空胶囊壳子。按她的说法，把药弄碎了放进去就不难吃了，后来我和她一起吃了。\"),\"\\n\",Vue.h(_components.p,null,\"……我当时究竟在搞什么……\"),\"\\n\",Vue.h(_components.p,null,\"结果是自己又好像觉得睡不着，又吃了氯硝西泮想要躺到床上去了。可也就是在那前后，她的手机和身份证不见了。\"),\"\\n\",Vue.h(_components.p,null,\"「这个之后慢慢找，我好累好困……先睡一下吧。」\"),\"\\n\",Vue.h(_components.p,null,\"可能是因为氯硝西泮的后劲太大，我再度醒来的时候，已经是在救护车上了。彩加就凑到我眼前和我说，她怎么喊都喊不醒我，便用我的手机打了 120。\"),\"\\n\",Vue.h(_components.p,null,\"「啥情况……我这不是清醒着吗，就是有点困……」因为没什么大碍，于是我结了救护车的费用，就同彩加回家继续休息了。\"),\"\\n\",Vue.h(_components.p,null,\"再醒来已是凌晨三四点，我发现手机不见了。通过 iCloud 的查找功能，发现定位在派出所。我披上衣服赶过去，果然在那边找到了她。\"),\"\\n\",Vue.h(_components.p,null,\"她穿着一身我没见过的衣服。后来才知道，是因为她只穿着上半身的衣服在外面跑，被人逮到派出所去了。\"),\"\\n\",Vue.h(_components.p,null,\"「妹，你怎么跑派出所来了？不回家吗，我们回家睡觉去呀！」我脑袋本也有点昏昏沉沉的。\"),\"\\n\",Vue.h(_components.p,null,\"然后我就把手机拿回来，牵着彩加的手回去了。\"),\"\\n\",Vue.h(_components.h2,null,\"梦碎\"),\"\\n\",Vue.h(_components.p,null,\"「我还想玩游戏，姐姐还能玩黑魂吗？」彩加回到家之后问我。\"),\"\\n\",Vue.h(_components.p,null,\"因为一直发生着许多事情，我还是感到好困好想休息，于是只能先安抚了下她，然后关灯睡了。\"),\"\\n\",Vue.h(\"details\",null,Vue.h(\"summary\",null,\"这回再次醒来，已是早上 6 点左右了。物业的人急匆匆地来敲我家的门，却并没有告诉我出了什么事。只说让我赶紧下楼。\"),Vue.h(_components.p,null,\"我在恍惚中下了楼。几个像是保安，抑或是警察的人领着我往前走。\"),Vue.h(_components.p,null,\"「怎么了这是……大清早的。我妹呢？」\"),Vue.h(_components.p,null,\"直到我走到了物业前的那片运动场地，角落中有一具凝滞的身形。\"),Vue.h(_components.p,null,\"我有些懵。这是什么……？这是谁……？\"),Vue.h(_components.p,null,\"那具身形背对着我，我仔细看了看她身上仅有的上衣，突然从朦胧中惊醒。\"),Vue.h(_components.p,null,\"「妹！你怎么了！妹！回答我啊！回应我一下吧……」我不断地呼喊着她，希望她能有点反应。\"),Vue.h(_components.p,null,\"但没有任何回应。\"),Vue.h(_components.p,null,\"围在她附近的保安也不让我靠近她。\"),Vue.h(_components.p,null,\"「哎，人已经走啦。刚刚救护车都来过了，看了下就走了。已经没有抢救的必要了。」旁边的大妈叹了口气，然后转过身去，不愿再理会我。\"),Vue.h(_components.p,null,\"警察也催着我走，好像是要我去做些什么，喊我别看了。\"),Vue.h(_components.p,null,\"可我还是舍不得，我的双腿就像灌了铅，好沉重，驻足在原地。\"),Vue.h(_components.p,null,\"他们走上前去，把彩加翻了个面。我才终于看清了她的脸庞。\")),\"\\n\",Vue.h(_components.p,null,\"泪水止不住地流下。\"),\"\\n\",Vue.h(_components.p,null,\"「对不起……姐姐没有保护好你……」\"),\"\\n\",Vue.h(_components.h2,null,\"缺失\"),\"\\n\",Vue.h(_components.p,null,\"做完笔录之后，派出所的人怕我情绪崩溃，一个人在重庆受不了直接寻死。于是我在里头被关了两天，直到我的母亲从新疆赶回重庆，才把我从派出所领出来。\"),\"\\n\",Vue.h(_components.p,null,\"「吃过饭了吗？」\"),\"\\n\",Vue.h(_components.p,null,\"「我什么都不想吃，也完全没有心情吃……」\"),\"\\n\",Vue.h(_components.p,null,\"说是这么说，但后来，我还是去了楼下的那家麦当劳买了麦旋风吃。\"),\"\\n\",Vue.h(_components.p,null,\"「彩加……爱吃这个。」\"),\"\\n\",Vue.h(_components.p,null,\"「别提这些了。」\"),\"\\n\",Vue.h(_components.p,null,\"再往回家的路走，我有意地走到那个运动场地的小角落。那里好像被打扫干净了，完全看不出这里昨天一早到底发生了什么。\"),\"\\n\",Vue.h(_components.p,null,\"一条生命，拉上警戒线，用罩子盖住，驱散人群，不一会儿，就好像这件事情从来没发生过一样。\"),\"\\n\",Vue.h(_components.p,null,\"那些目击了这场惨剧的人，又怎么会把这件事放在心上呢？他们很快便各自散去。\"),\"\\n\",Vue.h(_components.p,null,\"人群照旧来去匆匆，笑声与脚步声交错不息。到最后唯有我一人记得，这片大人小孩嬉戏的角落曾发生过什么。\"),\"\\n\",Vue.h(_components.h2,null,\"渝北\"),\"\\n\",Vue.h(_components.p,null,\"彩加走的时候还留下了两包没吃完的番茄方便面。\"),\"\\n\",Vue.h(_components.p,null,\"因为发生了这样的事情，我被家里人带走软禁起来了。后来，由于家庭原因，我彻底离开了重庆。\"),\"\\n\",Vue.h(_components.p,null,\"渝北的那个家是我回不去的家，承载着我的青春，也承载着我最痛苦的事。\"),\"\\n\",Vue.h(_components.p,null,\"三月，回到渝北旧居。给她带了几瓶复方甘草片。\"),\"\\n\",Vue.h(_components.p,null,\"怀念从前拿着预调酒兑可乐，吃甘草片和右美的日子。还有那条去取快递的小路。\"),\"\\n\",Vue.h(_components.p,null,\"她会记得这些吗？在不知何处，她有得到幸福吗……？\"),\"\\n\",Vue.h(_components.p,null,\"转眼间渝北之名也渐随风飘散，属于渝北的各种牌子被一块一块地摘下，取而代之的是两江新区\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-8\",id:\"footnote-ref-8\"},\"8\")),\"。\"),\"\\n\",Vue.h(_components.p,null,\"那段故事却永远留在了再也回不去的渝北。\"),\"\\n\",Vue.h(_components.h2,null,\"终章\"),\"\\n\",Vue.h(_components.p,null,\"OD 圈对彩加的影响太大了，如果不是那样，她或许会有一个不错的未来。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"彩加，一个小孩子。\"),\"\\n\",Vue.h(_components.p,null,\"……在我看来，就像豆花一样吧。\"),\"\\n\",Vue.h(_components.p,null,\"和什么人在一起，就会变成什么样子……\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"彩加走后，我在酒吧再没点过别的酒。只喝蓝色玛格丽特。每次去酒吧我都只点这个。虽然我其实一点也不喜欢喝这种……它的杯口沾着海盐，又苦又涩。\"),\"\\n\",Vue.h(_components.p,null,\"但那是我在酒吧喝的第一杯酒，也是她的第一杯酒。\"),\"\\n\",Vue.h(_components.p,null,\"条目贡献：\",Vue.h(_components.a,{href:\"https://twitter.com/Poetry_Luna\"},\"櫻崎詩月\")),\"\\n\",Vue.h(\"ol\",null,Vue.h(\"li\",{id:\"footnote-1\"},\"详见《魔法少女小圆》电视动画最终话《わたしの、最高の友達》。\",Vue.h(\"a\",{href:\"#footnote-ref-1\"},Vue.h(\"svg\",{viewBox:\"0 0 16 16\",version:\"1.1\",id:\"svg1\",\"xmlns:xlink\":\"http://www.w3.org/1999/xlink\",xmlns:\"http://www.w3.org/2000/svg\",\"xmlns:svg\":\"http://www.w3.org/2000/svg\",style:\"margin-left: 0.5rem; margin-bottom: -2px; width: 1rem; height: 1rem\"},Vue.h(\"defs\",