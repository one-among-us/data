"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({blockquote:\"blockquote\",em:\"em\",h2:\"h2\",p:\"p\"},props.components),CapDownQuote=_components.CapDownQuote;if(!CapDownQuote)_missingMdxReference(\"CapDownQuote\",true);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"Tenderness in the Corner\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT was a trans girl who endured a life of hardship.\\nShe had been shrouded in what seemed an endless gloom, yet her heart never ceased reaching towards the light.\"),\"\\n\",Vue.h(_components.p,null,\"The family she was born into was not a happy one.\\nHer parents never truly taught her how to be a decent person.\\nIt was books and visual novels that taught her love, courage, and all manner of virtue.\"),\"\\n\",Vue.h(_components.p,null,\"Her reading list ranged from works of great depth and fate such as \",Vue.h(_components.em,null,\"Faust\"),\" and \",Vue.h(_components.em,null,\"One Hundred Years of Solitude\"),\", to stories brimming with imagination and adventure like \",Vue.h(_components.em,null,\"The Adventures of Tom Sawyer\"),\" and \",Vue.h(_components.em,null,\"Gulliver’s Travels\"),\".\"),\"\\n\",Vue.h(_components.p,null,\"Visual novels were also a vital source of nourishment for her spirit.\\nWithin those worlds woven from text and choices, where branching storylines intertwined, she gradually formed her own values.\\nAmong the many titles she encountered, the one that left the deepest mark was the \",Vue.h(_components.em,null,\"Rance\"),\" series—and the character she loved most dearly was Shizuka Masou.\\nShizuka was a powerful and gifted magic user, carrying the trauma of her father’s early death and an obsession with vengeance, fighting against fate while holding fast to her own moral compass.\\nCold and distant on the surface, she concealed boundless tenderness and goodwill within.\\nShizuka’s strength of character profoundly influenced NIGHT, and so, throughout her life, she strove to embody the resilience, kindness, and quiet tenderness that Shizuka never easily revealed to others.\"),\"\\n\",Vue.h(_components.p,null,\"And yet, this resilient, kind, and gentle girl wrote the following confession:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"I want to become a person who is pure, flawless, and noble… but it seems that is no longer possible.\"),\"\\n\",Vue.h(_components.p,null,\"My heart is already filled with filth, and the wrongs I have committed can never be undone.\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"Defiance\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT’s father was a man who bullied the weak and cowered before the strong.\\nShe had been beaten by him since childhood.\\nBut eventually, he no longer dared to lay a hand on her.\\nNot because he had changed, but because she had relentlessly pushed herself to exercise, making her body strong.\"),\"\\n\",Vue.h(_components.p,null,\"On the pages of a diary already yellowed with age, her training results were recorded in clear black ink:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"Push-ups \\xd7 85\"),\"\\n\",Vue.h(_components.p,null,\"Squats \\xd7 110\"),\"\\n\",Vue.h(_components.p,null,\"Calf raises \\xd7 50\"),\"\\n\",Vue.h(_components.p,null,\"Sit-ups \\xd7 60\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"Years of persistent training gave her body the strength to stand against her father. At last, she could protect herself and her mother.\"),\"\\n\",Vue.h(_components.p,null,\"“You can call me a unfilial son if you want, but back then, I protected my mum. That’s one of the few things I can actually be proud of.”\"),\"\\n\",Vue.h(_components.p,null,\"Unable to subdue her with physical violence any longer, her father continued to wear down her dignity with degrading words.\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"I confronted my father: “Why did you have to cheat? Why did you have to betray us?”\"),\"\\n\",Vue.h(_components.p,null,\"He said, “All men are like this. Someday you’ll be just like me.”\"),\"\\n\",Vue.h(_components.p,null,\"I said I wouldn’t—I could never be like him, not in a lifetime. But he just said I was too young to understand.\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"Malice from Every Side\"),\"\\n\",Vue.h(_components.p,null,\"According to NIGHT’s own recollection, around the time of her senior high school entrance exams, she faced extreme bullying at school.\\nPerhaps because she could not bear to revisit those memories, she initially wrote the year as 2019, only realizing after putting it down that it should have been 2020.\"),\"\\n\",Vue.h(_components.p,null,\"At school, everyone mocked her for her unclear speech, imitating the way she talked to humiliate her.\\nThe experience left a deep scar—so much so that, from then on, she became acutely self-conscious about her voice.\\nShe grew unwilling to speak at all; no matter who called out to her, she would not answer. She no longer wanted to go to school, but at home she found no understanding either.\"),\"\\n\",Vue.h(_components.p,null,\"Her family humiliated her, saying things like “If you won’t study, go haul bricks at a construction site,” “You need to make something of yourself—if you can’t, you might as well be dead,” “How are you still alive,” and “Leave him a little knife so he can kill himself.”\"),\"\\n\",Vue.h(_components.p,null,\"She had no words to answer them and could only cry alone.\\nThere was nothing she could do, because her parents spent the entire day berating and dragging her down, and most of her time was consumed in these exhausting confrontations.\"),\"\\n\",Vue.h(_components.p,null,\"She spent half a year in utter futility.\\nIt was not until the day before her exams that she finally returned to school.\\nHer parents threatened that if she failed to get into high school, they would send her out to work.\"),\"\\n\",Vue.h(_components.p,null,\"Despite the enormous pressure, she managed to gain admission to a local high school.\\nBut when the time came to start, she was terrified of being humiliated again.\\nThough she still wanted to attend, the dread of reliving that nightmare ultimately led her to drop out.\"),\"\\n\",Vue.h(_components.p,null,\"Even after dropping out, her parents refused to let her stay home alone.\\nThey cut off her living expenses as leverage, coercing her into following them to Guangdong to work in their new venture.\"),\"\\n\",Vue.h(_components.p,null,\"Her parents had scraped together 300,000 yuan and opened a small textile dyeing factory in Dongguan.\\nThe workers were all relatives, and none of them were paid.\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT was also made to work there.\\nThe work itself was not strenuous, but the hours were excruciatingly long, and she received no pay whatsoever.\\nAfter a while, she refused to continue and locked herself in her room, eating and drinking nothing—and so she was constantly hungry.\\nIn the end, she had no choice but to work from time to time, if only to get a meal.\"),\"\\n\",Vue.h(_components.p,null,\"Yet even at work, she was subjected to a constant stream of abuse.\\nHer family called her worthless, and that crushing hostility only deepened the weight on her mind.\"),\"\\n\",Vue.h(_components.h2,null,\"Light in the Dead of Night\"),\"\\n\",Vue.h(_components.p,null,\"During those days in Guangdong, she was utterly alone.\\nHer only chance to download visual novels was late at night, using her parents’ mobile data while they slept.\"),\"\\n\",Vue.h(_components.p,null,\"She had no social contact at all—not even online.\\nHer sole companions, day after day, were the characters on the screen, carrying her through each agonising day.\"),\"\\n\",Vue.h(_components.p,null,\"She envied Rance, who could always set off on carefree adventures, whose friends were always by his side no matter what he did.\"),\"\\n\",Vue.h(_components.p,null,\"She envied Tear\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-1\",id:\"footnote-ref-1\"},\"1\")),\", who could become the wind and protect the one she loved.\"),\"\\n\",Vue.h(_components.p,null,\"She envied Tomoya\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-2\",id:\"footnote-ref-2\"},\"2\")),\", too—an ordinary person who lived a plain yet happy life.\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"A lot of my dreams took shape during that time—like wanting to be happy, things like that. But in the end, I suppose it was never really possible…\"),\"\\n\",Vue.h(_components.p,null,\"Even though I couldn’t get enough to eat back then, had no friends at all, and was berated all day long.\"),\"\\n\",Vue.h(_components.p,null,\"I still miss that time. I miss every day those fictional characters spent by my side. I’m grateful they kept me company through all that loneliness.\"),\"\\n\",Vue.h(_components.p,null,\"Those lonely, painful days dragged on and on, but those games were among the very few lights that kept shining on me.\"),\"\\n\",Vue.h(_components.p,null,\"And yet I couldn’t keep up with that light, and just kept sinking further and further down…\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"The God Above\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT had a strong religious inclination, and so there was always a figure she called “the God Above” in her heart.\"),\"\\n\",Vue.h(_components.p,null,\"Though she never knew who the God Above was, she held fast to the belief that one day, the God Above would come to save her.\"),\"\\n\",Vue.h(_components.p,null,\"In earlier times, she would always pray to the God Above—praying for someone, praying for tomorrow.\"),\"\\n\",Vue.h(_components.p,null,\"When she was hungry, she would pray to the God Above.\"),\"\\n\",Vue.h(_components.p,null,\"Before meals, she would give thanks for the God Above’s protection, believing it was the God Above who had spared her from hunger.\"),\"\\n\",Vue.h(_components.p,null,\"Sometimes, she also felt the God Above was terribly unfair, unwilling to spare her even the smallest grace.\"),\"\\n\",Vue.h(_components.p,null,\"But after a certain event, she never prayed again.\"),\"\\n\",Vue.h(_components.p,null,\"Because she came to feel that the God Above would never shine any light upon her.\"),\"\\n\",Vue.h(\"blockquote\",null,Vue.h(CapDownQuote,{messages:[[\"Crying, wondering when the God Above would be a little kinder to me”\",\"“When will tomorrow get better”\"],[\"“I told myself tomorrow would be better”\",\"“As long as I wait until tomorrow, everything will be fine”\"],[\"“But when tomorrow came, nothing had changed from yesterday after all”\"],[\"“Still the same nightmarish days as yesterday”\",\"“No idea when it will ever end”\",\"“Life is nothing but a living nightmare”\"],[\"“Only when I’m asleep can I rest”\",\"“There probably never was any God Above”\"],[\"“But I still can’t help thinking…”\",\"<span style='font-size: 200%; font-weight: bold;'>“The God Above”</span>\"]]})),\"\\n\",Vue.h(_components.h2,null,\"To Live\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT also spent a great deal of time contemplating the subject of life itself.\"),\"\\n\",Vue.h(_components.p,null,\"In the summer of 2021, the bitterness of life overwhelmed her, and she attempted to free herself from this world.\\nTwo years later, looking back on what had happened, she felt that her life had actually been getting better—and that, paradoxically, she had lost the courage to die.\"),\"\\n\",Vue.h(_components.p,null,\"She read Yu Hua’s \",Vue.h(_components.em,null,\"To Live\"),\" and came upon the line: “People live for the sake of living itself, not for anything beyond living.”\\nShe then wrote the following:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"The word “people” in this sentence is a broad category—meaning you can substitute any specific person.\"),\"\\n\",Vue.h(_components.p,null,\"For example, Gagarin was a person, so you could conclude that Gagarin lived for the sake of living itself, not for anything beyond living—which is obviously wrong. The same substitution works with any historical figure.\"),\"\\n\",Vue.h(_components.p,null,\"But if the meaning of living is simply living, then that amounts to saying living has no meaning—just as saying the meaning of snowfall is snowfall. From this, you could conclude that all those historical figures lived meaningless lives.\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT said these words to herself, but the word “living” only grew heavier because of them. At night, she wiped away her tears in secret, leaving herself with nothing more than the simplest of sentences:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"Tomorrow, I must keep on living.\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"She wondered: how would she have to live in order to say, as Wittgenstein did on his deathbed, “Tell them I’ve had a wonderful life”?\"),\"\\n\",Vue.h(_components.p,null,\"A few days later, she wrote:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"Well… if I were to die, all I could say would be, “I lived an unhappy life, full of regrets.”\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"Sadly, as time went on, NIGHT came to feel that she had been living in the past all along.\\nWhat she chased was a happiness that had already been, and she realized those days could never return.\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"Perhaps I died back in those long-gone, unreachable days, and surviving was nothing but an accident.\"),\"\\n\",Vue.h(_components.p,null,\"Just as the final line of \",Vue.h(_components.em,null,\"The Great Gatsby\"),\" says:\"),\"\\n\",Vue.h(_components.p,null,\"“So we beat on, boats against the current, borne back ceaselessly into the past.”\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"A Hot Bath\"),\"\\n\",Vue.h(_components.p,null,\"In her daily life, the happiest moment was always when she took a hot bath.\"),\"\\n\",Vue.h(_components.p,null,\"And so she would always stay in there for a very, very long time… even if she did nothing at all, just letting the hot water pour over her.\"),\"\\n\",Vue.h(_components.p,null,\"And so, she made a small, quiet wish:\"),\"\\n\",Vue.h(_components.p,null,\"She hoped that one day, her home would have a rain showerhead—one that fell like rain. That way, she wouldn’t have to hold the showerhead in her hand.\"),\"\\n\",Vue.h(_components.p,null,\"And then… playing music while she bathed. That alone would make her happy.\"),\"\\n\",Vue.h(_components.p,null,\"“Oh my… I’ve never even used a bathtub,” she said.\"),\"\\n\",Vue.h(_components.p,null,\"“If only I had a thermostat bathtub… it would be so lovely to just soak in it forever.”\"),\"\\n\",Vue.h(_components.h2,null,\"Flight and Respite\"),\"\\n\",Vue.h(_components.p,null,\"In the spring of 2024, she could no longer endure her parents and their small factory in Guangdong, and so she set out on a journey of escape.\"),\"\\n\",Vue.h(_components.p,null,\"She settled into a long-term stay at a hotel in the Yangtze River Delta. Though things were somewhat calmer, life still refused to let her be.\"),\"\\n\",Vue.h(_components.p,null,\"“Bitter liquor, much like a bitter life—hard to swallow, yet impossible to refuse.”\"),\"\\n\",Vue.h(_components.p,null,\"While staying at the hotel, she slept so deeply that the staff mistook it for a suicide attempt.\\nThough the misunderstanding caused a bit of trouble, she felt, in it, a small touch of care.\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"If only I really had a home, I wouldn’t have to stay in a hotel.\"),\"\\n\",Vue.h(_components.p,null,\"Maybe I’m dreaming. I really do have a home—hazy, drifting. I must be dreaming.\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"Even while drifting from place to place, she held on to the goodness in her heart.\\nShe took in a penniless, homeless trans girl, and paid out of her own pocket to cover the girl’s travel fare so she could travel on.\"),\"\\n\",Vue.h(_components.p,null,\"She had wanted to go further, but she was tired.\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"I had planned to go to Beijing, to Tianjin, or somewhere even further.\"),\"\\n\",Vue.h(_components.p,null,\"But I’m too tired. I’ll just settle down in Nanjing. I don’t want to go anywhere any more.\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"Final Words\"),\"\\n\",Vue.h(_components.p,null,\"She did not want her emotions controlled by medication.\"),\"\\n\",Vue.h(_components.p,null,\"She threw away all her pills.\"),\"\\n\",Vue.h(_components.p,null,\"She wanted love, yet could not feel it.\"),\"\\n\",Vue.h(_components.p,null,\"She wanted to leave, yet had lost the ability to make decisions—and so she cast the dice of fate.\"),\"\\n\",Vue.h(_components.p,null,\"She never said what the dice showed. But she decided to listen to fate once more.\"),\"\\n\",Vue.h(_components.p,null,\"Yet she was too weary of living, and no amount of alcohol could suppress the despair in her heart…\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"We will never see each other again.\"),\"\\n\",Vue.h(_components.p,null,\"But I think, in the end, a small farewell is still needed—\"),\"\\n\",Vue.h(_components.p,null,\"My friend, thank you for appearing in my life.\"),\"\\n\",Vue.h(_components.p,null,\"Thank you for staying by my side all this time.\"),\"\\n\",Vue.h(_components.p,null,\"When you wake tomorrow morning, it will be a brand-new day.\"),\"\\n\",Vue.h(_components.p,null,\"It’s just that I no longer have a tomorrow. I can no longer pray for yours.\"),\"\\n\",Vue.h(_components.p,null,\"So this time, I sincerely wish you happiness.\"),\"\\n\",Vue.h(_components.p,null,\"Please forget me.\"),\"\\n\",Vue.h(_components.p,null,\"And finally, goodbye…\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"Perhaps she left because of that belief—that her happiness had been forever stranded in the past…\"),\"\\n\",Vue.h(_components.p,null,\"Just as the ending of her beloved \",Vue.h(_components.em,null,\"The Great Gatsby\"),\" says:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"So we beat on, boats against the current, borne back ceaselessly into the past.\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"A Belated Greeting\"),\"\\n\",Vue.h(_components.p,null,\"A year after she passed away, we heard from her once more:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"This is a scheduled post from 2024.\"),\"\\n\",Vue.h(_components.p,null,\"Today is my birthday—please wish me a happy birthday~\"),\"\\n\",Vue.h(_components.p,null,\"A year has gone by. How is everyone doing?\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"Dear NIGHT, the world may be getting worse, but we have never stopped trying.\"),\"\\n\",Vue.h(_components.p,null,\"Even if the world has not become a better place, we keep striving to become better ourselves.\"),\"\\n\",Vue.h(_components.p,null,\"And—happy birthday.\"),\"\\n\",Vue.h(\"ol\",null,Vue.h(\"li\",{id:\"footnote-1\"},\"A character from \",Vue.h(_components.em,null,\"That Time I Got Reincarnated as a Slime\"),\".\",Vue.h(\"a\",{href:\"#footnote-ref-1\"},Vue.h(\"svg\",{viewBox:\"0 0 16 16\",version:\"1.1\",id:\"svg1\",\"xmlns:xlink\":\"http://www.w3.org/1999/xlink\",xmlns:\"http://www.w3.org/2000/svg\",\"xmlns:svg\":\"http://www.w3.org/2000/svg\",style:\"margin-left: 0.5rem; margin-bottom: -2px; width: 1rem; height: 1rem\"},Vue.h(\"defs\",{id:\"defs1\"},Vue.h(\"linearGradient\",{id:\"linearGradient3\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop3\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop4\"})),Vue.h(\"linearGradient\",{id:\"linearGradient1\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop1\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop2\"})),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient1\",id:\"linearGradient2\",x1:\"2.6681123\",y1:\"8\",x2:\"13.331888\",y2:\"8\",gradientUnits:\"userSpaceOnUse\",gradientTransform:\"translate(2.6678295,-2)\"}),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient3\",id:\"linearGradient4\",x1:\"3.7075224\",y1:\"8\",x2:\"12.292478\",y2:\"8\",gradientUnits:\"userSpaceOnUse\"})),Vue.h(\"g\",{id:\"layer1\",transform:\"translate(0,2)\"},Vue.h(\"circle\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient2);stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",id:\"path1\",cx:\"10.667834\",cy:\"6\",r:\"4.5818877\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:#ff8373;stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",d:\"M 9.9178343,10.577036 H 1.7971455\",id:\"path2\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient4);stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",id:\"path3\",d:\"M 8.0000001,11.231817 4.7681825,8.0000001 7.9999999,4.7681825 11.231817,7.9999999 Z\",transform:\"translate(-3.6894439,2.577036)\"}))))),Vue.h(\"li\",{id:\"footnote-2\"},\"Tomoya Okazaki, a character from the visual novel \",Vue.h(_components.em,null,\"CLANNAD\"),\" by Key.\",Vue.h(\"a\",{href:\"#footnote-ref-2\"},Vue.h(\"svg\",{viewBox:\"0 0 16 16\",version:\"1.1\",id:\"svg1\",\"xmlns:xlink\":\"http://www.w3.org/1999/xlink\",xmlns:\"http://www.w3.org/2000/svg\",\"xmlns:svg\":\"http://www.w3.org/2000/svg\",style:\"margin-left: 0.5rem; margin-bottom: -2px; width: 1rem; height: 1rem\"},Vue.h(\"defs\",{id:\"defs1\"},Vue.h(\"linearGradient\",{id:\"linearGradient3\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop3\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop4\"})),Vue.h(\"linearGradient\",{id:\"linearGradient1\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop1\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop2\"})),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient1\",id:\"linearGradient2\",x1:\"2.6681123\",y1:\"8\",x2:\"13.331888\",y2:\"8\",gradientUnits:\"userSpaceOnUse\",gradientTransform:\"translate(2.6678295,-2)\"}),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient3\",id:\"linearGradient4\",x1:\"3.7075224\",y1:\"8\",x2:\"12.292478\",y2:\"8\",gradientUnits:\"userSpaceOnUse\"})),Vue.h(\"g\",{id:\"layer1\",transform:\"translate(0,2)\"},Vue.h(\"circle\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient2);stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",id:\"path1\",cx:\"10.667834\",cy:\"6\",r:\"4.5818877\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:#ff8373;stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",d:\"M 9.9178343,10.577036 H 1.7971455\",id:\"path2\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient4);stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",id:\"path3\",d:\"M 8.0000001,11.231817 4.7681825,8.0000001 7.9999999,4.7681825 11.231817,7.9999999 Z\",transform:\"translate(-3.6894439,2.577036)\"})))))))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout,_extends({},props),Vue.h(_createMdxContent,_extends({},props))):_createMdxContent(props)}function _missingMdxReference(id,component){throw new Error(\"Expected \"+(component?\"component\":\"object\")+\" `\"+id+\"` to be defined: you likely forgot to import, pass, or provide it.\")}"