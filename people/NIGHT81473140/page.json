"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components),CapDownQuote=_components.CapDownQuote;if(!CapDownQuote)_missingMdxReference(\"CapDownQuote\",true);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"角落里的温柔\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT，一位经历生活坎坷的跨性别女孩。她曾笼罩在无边的阴霾之中，却依然心向光明。\"),\"\\n\",Vue.h(_components.p,null,\"她出身的家庭并不幸福，她的父母未曾真正教她如何做人，是书本和 Gal 游戏教会了她爱与勇气，以及种种的美德。\"),\"\\n\",Vue.h(_components.p,null,\"她的文学书单内既有《浮士德》《百年孤独》如此充满深度与命运感的作品，也有《汤姆\\xb7索亚历险记》《格列佛游记》这样充满想象与冒险的故事。\"),\"\\n\",Vue.h(_components.p,null,\"Gal 游戏亦是她曾经的精神食粮，在那些由文字与选择组成的交错相织的世界线之中，她逐渐形成了自己的价值观。在众多作品之中，对她影响最深的是《兰斯》系列，她很喜欢很喜欢《兰斯》系列中的魔想志津香。那是一位强大的天才女魔法师，背负着早年父亲离世的创伤与复仇的执念，一边对抗命运，一边守住内心的道德底线。外表冷淡而疏离，内心却隐藏着无限的温柔与善意。志津香的人格魅力深深影响了 NIGHT，因此，她在生活中一直在追寻着志津香身上的坚强与善良，以及那从不轻易示人的温柔。\"),\"\\n\",Vue.h(_components.p,null,\"这样一个坚强、善良、温柔的孩子，却写下了这样的自白：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我想要成为一个纯洁无瑕而又高贵的人……但似乎已经不可能了，我的内心已经充满了污秽，所犯下的恶也无法弥补。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"反抗\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 的父亲是个欺软怕硬的人，她从小被他打到大。但后来，她的父亲不敢对她动手了。这并非是缘于父亲变好了，而是因着她总是逼迫自己锻炼，让身体变得强壮。\"),\"\\n\",Vue.h(_components.p,null,\"在那本已经有些泛黄的日记本上，黑色的笔迹清晰地记录着她当年的锻炼成果：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"俯卧撑 \\xd7 85\"),\"\\n\",Vue.h(_components.p,null,\"深蹲 \\xd7 110\"),\"\\n\",Vue.h(_components.p,null,\"提踵 \\xd7 50\"),\"\\n\",Vue.h(_components.p,null,\"仰卧起坐 \\xd7 60\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"十足长久的锻炼让她的身体有了对抗父亲的资本，她终于可以保护自己与母亲了。\"),\"\\n\",Vue.h(_components.p,null,\"「你可以说我是个带孝子，但是在那个时候，我保护了自己的妈妈，这是我少数可以值得骄傲的事情了。」\"),\"\\n\",Vue.h(_components.p,null,\"父亲无法再用肢体暴力来压制她，却依旧用侮辱性的语言消磨她的尊严。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我质问着我的父亲：「为什么要出轨呢？为什么要背叛呢？」\"),\"\\n\",Vue.h(_components.p,null,\"他说，「所有的男人都会这样，以后你也会像我一样。」\"),\"\\n\",Vue.h(_components.p,null,\"我说我不，我永远不可能像他一样，一辈子也不可能。他却说我还小不懂这些。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"四方恶语\"),\"\\n\",Vue.h(_components.p,null,\"据 NIGHT 的回忆，临近中考那会儿，她面临着极度糟糕的校园暴力。也许是因为内心不愿忆起，她刚开始时记作 2019 年，写下之后才意识到应是 2020 年。\"),\"\\n\",Vue.h(_components.p,null,\"那时，在学校里，大家都嘲笑她的口齿不清，总是学她说话来羞辱她。这段经历给她带来深深的阴影，以至于到后来，她十分介意自己的声音。她变得不愿意开口说话，无论是谁叫她，她都不愿意应答了。她也不愿意再去学校了，但她在家也没有获得理解。\"),\"\\n\",Vue.h(_components.p,null,\"家长羞辱她，说什么「不读书就去工地搬砖」「做人要争气，不争气还不如去死」「你这样的人怎么还不去死」「留把小刀给他自杀用吧」。她对此哑口无言，只能一个人哭泣，她没有办法做任何事，因为家长一整天都在羞辱她，拉扯她，大部分的时间都在与父母的拉扯之间浪费掉了。\"),\"\\n\",Vue.h(_components.p,null,\"她度过了毫无意义的半年。直到中考前一天，她才回到了学校。父母还威胁她，如果她考不上高中，就让她去外面打工。\"),\"\\n\",Vue.h(_components.p,null,\"尽管顶着巨大的压力，她还是考上了本地的普通高中。可在开学的时候，她害怕再度被羞辱。尽管她还是想要去上学的，但最终因着对曾经那段阴影的畏惧，她休学了。\"),\"\\n\",Vue.h(_components.p,null,\"虽说休了学，但她的父母也不愿意让她在家独居，就以断掉生活费相要挟，威胁她随他们去广东打工创业。\"),\"\\n\",Vue.h(_components.p,null,\"她的父母东拼西凑了三十万元，在东莞开了一个小小的纺织染色工厂，工人都是他们的亲戚，但没有工资。\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 也被要求去帮他们工作，虽说工作很轻松，但工作时间很长很长，也没有任何薪水。于是，她在一段时间之后就不愿干了，并将自己锁进了房间里，不吃不喝，因而她总是挨饿。最后还是不得不偶尔去工作来蹭饭吃。\"),\"\\n\",Vue.h(_components.p,null,\"可哪怕是工作也要一直被恶言相向。她被家人羞辱是个废物，那种极大的恶意进一步加重了她的精神压力。\"),\"\\n\",Vue.h(_components.h2,null,\"深夜中的光\"),\"\\n\",Vue.h(_components.p,null,\"在广东的日子里很孤独，她只能趁着父母晚上回来睡觉的时间用他们的数据流量下载 Gal。\"),\"\\n\",Vue.h(_components.p,null,\"那时，她没有任何社交，哪怕是在网上。每天陪伴她的只有 Gal 游戏里中的小人，以此来度过煎熬的每一天。\"),\"\\n\",Vue.h(_components.p,null,\"她很羡慕兰斯。那是一个永远可以无忧无虑地大冒险的角色，不管做什么朋友们也总是陪伴着他。\"),\"\\n\",Vue.h(_components.p,null,\"她很羡慕缇娅\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-1\",id:\"footnote-ref-1\"},\"1\")),\"，能成为风守护自己的爱人。\"),\"\\n\",Vue.h(_components.p,null,\"她也很羡慕朋也\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-2\",id:\"footnote-ref-2\"},\"2\")),\"，作为普通人度过了平凡而幸福的一生。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我的很多梦想什么的也都是在那时候有的，比如想要变得幸福什么的，不过终究是不可能的吧……\"),\"\\n\",Vue.h(_components.p,null,\"虽然那时候吃不饱，没有任何朋友，还整天要被辱骂。\"),\"\\n\",Vue.h(_components.p,null,\"但是我还是很怀念那个时候，怀念这些纸片人陪伴我度过的每一天，感谢他们一直陪伴着孤单的我。\"),\"\\n\",Vue.h(_components.p,null,\"孤单而痛苦的日子虽然很漫长，但这些游戏却是为数不多一直照耀着我的光芒了。\"),\"\\n\",Vue.h(_components.p,null,\"可我却没能追上这些光芒而一直沉沦了下去……\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"神明大人\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 有着强烈的宗教倾向，因而在她的心中，总有着一位「神明大人」。\"),\"\\n\",Vue.h(_components.p,null,\"虽然她并不知道神明大人是谁，但她一直坚信着神明大人总有一天会来拯救她。\"),\"\\n\",Vue.h(_components.p,null,\"从前，她总是会对着「神明大人」祈祷，为某人祈祷，为明天而祈祷。\"),\"\\n\",Vue.h(_components.p,null,\"肚子饿了的时候，她会向「神明大人」祷告。\"),\"\\n\",Vue.h(_components.p,null,\"饭前祷告之时，她会感激神明大人的庇护，因为她觉得是神明大人让她不用忍饥挨饿了。\"),\"\\n\",Vue.h(_components.p,null,\"有时候，她也会觉得神明大人很过分，一点点的恩泽也不愿意分给她。\"),\"\\n\",Vue.h(_components.p,null,\"可自从某件事情以后，她再也不会祈祷了。\"),\"\\n\",Vue.h(_components.p,null,\"因为她感受到她的神明大人永远不愿意将光辉照耀到她的身上。\"),\"\\n\",Vue.h(\"blockquote\",null,Vue.h(CapDownQuote,{messages:[[\"哭着想着神明大人什么时候能对我温柔一点呢”\",\"“明天什么时候能变得好起来呢”\"],[\"“我安慰自己明天就会好起来了”\",\"“只要等到明天什么都会好起来的”\"],[\"“可是明天到来了终究还是和昨天一样什么都没有变”\"],[\"“还是和昨天一样噩梦般的日子”\",\"“也不知道什么时候能结束”\",\"“生活简直就是在做噩梦”\"],[\"“只有睡着的时候能休息”\",\"“大概从来没有什么神明大人”\"],[\"“但我还是忍不住想着……”\",\"<span style='font-size: 200%; font-weight: bold;'>“神明大人”</span>\"]]})),\"\\n\",Vue.h(_components.h2,null,\"活着\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 也一直在思考着关于生命的话题。\"),\"\\n\",Vue.h(_components.p,null,\"2021 年的夏天，生活的苦涩压倒了她，她曾试图从这个世界上解脱。两年后，当她回想起那件事，却觉得自己的生活越来越好了，反倒失去了去死的勇气。\"),\"\\n\",Vue.h(_components.p,null,\"她读余华的《活着》，看到那句「人是为了活着本身而活着，而不是为了活着之外的任何事物而活着」，于是写下了这样的话：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"这句话中的人，是一个大的集合，也就是说可以代入具体的人。\"),\"\\n\",Vue.h(_components.p,null,\"例如加加林也是一个人，那么就可以得出结论，加加林活着是为了活着本身，而不是为了活着之外的任何事物活着，这样这句话明显就是错误。同样地，可以代入任何历史人物。\"),\"\\n\",Vue.h(_components.p,null,\"但是假如活着的意义就是活着，意思就是活着没有意义了，就像是是说下雪的意义就是下雪一样。这么就可以得出结论那么多的历史人物活着都是无意义的。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 把这段道理说给自己听，「活着」这个词却因此变得更加沉重。夜里，她偷偷抹去眼泪，只给自己留下一句再简单不过的话：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"明天也要努力活着。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"她想着，要如何活着才能像维特根斯坦一样在临死时说「告诉他们我度过了幸福的一生」呢？\"),\"\\n\",Vue.h(_components.p,null,\"几天之后，她写道：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"嘛……我要是死去的话，只能说「我度过了一个不幸而充满遗憾的一生。」\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"只可惜后来，NIGHT 感受到自己一直活在过去，她追逐的是过去的幸福，可她发现往昔的日子已然回不去了。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我也许是死在以前那些遥不可及的日子里了，活下来只是个意外罢了。\"),\"\\n\",Vue.h(_components.p,null,\"就如《了不起的盖茨比》中的最后那句话所言：\"),\"\\n\",Vue.h(_components.p,null,\"「我们奋力向前，宛如逆水行舟，与激流抗争勇进，直至淹没入岁月长河。」\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"热水澡\"),\"\\n\",Vue.h(_components.p,null,\"平日里，对她来说最幸福的时刻，就是洗热水澡的时候。\"),\"\\n\",Vue.h(_components.p,null,\"所以她总是要洗很久很久……哪怕什么也不做，就让热水一直洒在身上。\"),\"\\n\",Vue.h(_components.p,null,\"所以，她许下了一点小小的愿望：\"),\"\\n\",Vue.h(_components.p,null,\"她希望她以后的房子能有个顶喷花洒，像淋雨一样。这样就不需要用手拿着花洒了。\"),\"\\n\",Vue.h(_components.p,null,\"然后就是……边洗澡边放歌，这样就很幸福了。\"),\"\\n\",Vue.h(_components.p,null,\"「啊啦……我还没有用过浴缸呢……」她说道。\"),\"\\n\",Vue.h(_components.p,null,\"「要是有恒温浴缸就好啦……进去一直泡着一定会很舒服。」\"),\"\\n\",Vue.h(_components.h2,null,\"逃亡与喘息\"),\"\\n\",Vue.h(_components.p,null,\"2024 年春，她再也受不了父母和她们在广东的小工厂，于是开始了自己的逃亡之旅。\"),\"\\n\",Vue.h(_components.p,null,\"她到长三角的一处宾馆长租住下，虽然稍微平静了些许，但生活还是不愿意放过她。\"),\"\\n\",Vue.h(_components.p,null,\"「苦涩的酒如同苦涩的人生一样，难以下咽，却不得不接受。」\"),\"\\n\",Vue.h(_components.p,null,\"在宾馆里，她因为睡得太沉，被宾馆工作人员以为是自杀。虽然这样的误会造成了些许麻烦，但她却感到一丝关怀。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"要是我真的有个家就好了，也就不用来宾馆了。\"),\"\\n\",Vue.h(_components.p,null,\"也许我在做梦，我真的拥有了一个家，恍恍惚惚，我一定是在做梦。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"即使是在外漂泊，她也依然保持着自己内心的善意，收留了一位身无分文、无家可归的 MtF，还自掏腰包为她凑了离开的路费。\"),\"\\n\",Vue.h(_components.p,null,\"她本想走得更远，但她累了。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我本想去北京，去天津，还是更远更远的地方。\"),\"\\n\",Vue.h(_components.p,null,\"不过我太累啦，我就在南京定居下来吧，我哪都不想去了。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"绝笔\"),\"\\n\",Vue.h(_components.p,null,\"她不想被药物控制情绪。\"),\"\\n\",Vue.h(_components.p,null,\"她把所有的药都扔掉了。\"),\"\\n\",Vue.h(_components.p,null,\"她想要爱，却又感受不到爱。\"),\"\\n\",Vue.h(_components.p,null,\"她想要离开，却已失去了做决定的能力，于是掷出了命运的骰子。\"),\"\\n\",Vue.h(_components.p,null,\"骰子的结果，她没有明说。但她还是决定再听一听天意。\"),\"\\n\",Vue.h(_components.p,null,\"但她活得太累了，再多的酒精也压不住她心中的绝望……\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"以后我们再也不会相见了。\"),\"\\n\",Vue.h(_components.p,null,\"但是我想，到最后还是需要一声小小的道别——\"),\"\\n\",Vue.h(_components.p,null,\"我的朋友，感谢你出现在我的生命中。\"),\"\\n\",Vue.h(_components.p,null,\"感谢你对我一直以来的陪伴。\"),\"\\n\",Vue.h(_components.p,null,\"明天清早醒来，又会是崭新的一天。\"),\"\\n\",Vue.h(_components.p,null,\"只是我再也没有明天了，我再也无法为你的明天祈祷。\"),\"\\n\",Vue.h(_components.p,null,\"所以这次，我由衷地祝福你，希望你幸福。\"),\"\\n\",Vue.h(_components.p,null,\"请忘记我吧。\"),\"\\n\",Vue.h(_components.p,null,\"最后，再见……\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"或许，她的离开，真的是因为那句「自己的幸福永远地停留在过去」……\"),\"\\n\",Vue.h(_components.p,null,\"也正如她所喜爱的《了不起的盖茨比》结尾中所言吧：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"So we beat on, boats against the current, borne back ceaselessly into the past.\"),\"\\n\",Vue.h(_components.p,null,\"我们奋力向前，宛如逆水行舟，与激流抗争勇进，直至淹没入岁月长河。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"迟来的问候\"),\"\\n\",Vue.h(_components.p,null,\"自她离世一年以后，我们再度听到了来自她的问候：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"这是一条来自 2024 年的定时推文哦。\"),\"\\n\",Vue.h(_components.p,null,\"今天是我的生日呢，请祝我生日快乐~\"),\"\\n\",Vue.h(_components.p,null,\"一年过去啦，大家变得怎么样了呢？\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"亲爱的 NIGHT，世界或许在变糟，但我们一直在努力。\"),\"\\n\",Vue.h(_components.p,null,\"哪怕世界没有变得更好，我们也在不断尝试变得更好。\"),\"\\n\",Vue.h(_components.p,null,\"以及，生日快乐。\"),\"\\n\",Vue.h(\"ol\",null,Vue.h(\"li\",{id:\"footnote-1\"},\"《关于我转生变成史莱姆这档事》中的角色。\",Vue.h(\"a\",{href:\"#footnote-ref-1\"},Vue.h(\"svg\",{viewBox:\"0 0 16 16\",version:\"1.1\",id:\"svg1\",\"xmlns:xlink\":\"http://www.w3.org/1999/xlink\",xmlns:\"http://www.w3.org/2000/svg\",\"xmlns:svg\":\"http://www.w3.org/2000/svg\",style:\"margin-left: 0.5rem; margin-bottom: -2px; width: 1rem; height: 1rem\"},Vue.h(\"defs\",{id:\"defs1\"},Vue.h(\"linearGradient\",{id:\"linearGradient3\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop3\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop4\"})),Vue.h(\"linearGradient\",{id:\"linearGradient1\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop1\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop2\"})),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient1\",id:\"linearGradient2\",x1:\"2.6681123\",y1:\"8\",x2:\"13.331888\",y2:\"8\",gradientUnits:\"userSpaceOnUse\",gradientTransform:\"translate(2.6678295,-2)\"}),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient3\",id:\"linearGradient4\",x1:\"3.7075224\",y1:\"8\",x2:\"12.292478\",y2:\"8\",gradientUnits:\"userSpaceOnUse\"})),Vue.h(\"g\",{id:\"layer1\",transform:\"translate(0,2)\"},Vue.h(\"circle\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient2);stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",id:\"path1\",cx:\"10.667834\",cy:\"6\",r:\"4.5818877\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:#ff8373;stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",d:\"M 9.9178343,10.577036 H 1.7971455\",id:\"path2\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient4);stroke-width:1.5;stroke-linecap