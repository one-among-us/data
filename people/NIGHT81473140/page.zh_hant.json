"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components),CapDownQuote=_components.CapDownQuote;if(!CapDownQuote)_missingMdxReference(\"CapDownQuote\",true);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"角落裡的溫柔\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT，一位經歷生活坎坷的跨性別女孩。她曾籠罩在無邊的陰霾之中，卻依然心向光明。\"),\"\\n\",Vue.h(_components.p,null,\"她出身的家庭並不幸福，她的父母未曾真正教她如何做人，是書本和 Gal 遊戲教會了她愛與勇氣，以及種種的美德。\"),\"\\n\",Vue.h(_components.p,null,\"她的文學書單內既有《浮士德》《百年孤寂》如此充滿深度與命運感的作品，也有《湯姆歷險記》《格列佛遊記》這樣充滿想像與冒險的故事。\"),\"\\n\",Vue.h(_components.p,null,\"Gal 遊戲亦是她曾經的精神食糧，在那些由文字與選擇組成的交錯相織的世界線之中，她逐漸形成了自己的價值觀。在眾多作品之中，對她影響最深的是《蘭斯》系列，她很喜歡很喜歡《蘭斯》系列中的魔想志津香。那是一位強大的天才女魔法師，背負著早年父親離世的創傷與復仇的執念，一邊對抗命運，一邊守住內心的道德底線。外表冷淡而疏離，內心卻隱藏著無限的溫柔與善意。志津香的人格魅力深深影響了 NIGHT，因此，她在生活中一直在追尋著志津香身上的堅強與善良，以及那從不輕易示人的溫柔。\"),\"\\n\",Vue.h(_components.p,null,\"這樣一個堅強、善良、溫柔的孩子，卻寫下了這樣的自白：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我想要成為一個純潔無瑕而又高貴的人……但似乎已經不可能了，我的內心已經充滿了污穢，所犯下的惡也無法彌補。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"反抗\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 的父親是個欺軟怕硬的人，她從小被他打到大。但後來，她的父親不敢對她動手了。這並非是緣於父親變好了，而是因著她總是逼迫自己鍛鍊，讓身體變得強壯。\"),\"\\n\",Vue.h(_components.p,null,\"在那本已經有些泛黃的日記本上，黑色的筆跡清晰地記錄著她當年的鍛鍊成果：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"俯臥撐\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-1\",id:\"footnote-ref-1\"},\"1\")),\" \\xd7 85\"),\"\\n\",Vue.h(_components.p,null,\"深蹲 \\xd7 110\"),\"\\n\",Vue.h(_components.p,null,\"提踵 \\xd7 50\"),\"\\n\",Vue.h(_components.p,null,\"仰臥起坐 \\xd7 60\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"十足長久的鍛鍊讓她的身體有了對抗父親的資本，她終於可以保護自己與母親了。\"),\"\\n\",Vue.h(_components.p,null,\"「你可以說我是個『帶孝子』，但是在那個時候，我保護了自己的媽媽，這是我少數可以值得驕傲的事情了。」\"),\"\\n\",Vue.h(_components.p,null,\"父親無法再用肢體暴力來壓制她，卻依舊用侮辱性的語言消磨她的尊嚴。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我質問著我的父親：「為什麼要出軌呢？為什麼要背叛呢？」\"),\"\\n\",Vue.h(_components.p,null,\"他說，「所有的男人都會這樣，以後你也會像我一樣。」\"),\"\\n\",Vue.h(_components.p,null,\"我說我不，我永遠不可能像他一樣，一輩子也不可能。他卻說我還小不懂這些。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"四方惡語\"),\"\\n\",Vue.h(_components.p,null,\"據 NIGHT 的回憶，臨近中考那會兒，她面臨著極度糟糕的校園霸凌。也許是因為內心不願憶起，她剛開始時記作 2019 年，寫下之後才意識到應是 2020 年。\"),\"\\n\",Vue.h(_components.p,null,\"那時，在學校裡，大家都嘲笑她的口齒不清，總是學她說話來羞辱她。這段經歷給她帶來深深的陰影，以至於到後來，她十分介意自己的聲音。她變得不願意開口說話，無論是誰叫她，她都不願意應答了。她也不願意再去學校了，但她在家也沒有獲得理解。\"),\"\\n\",Vue.h(_components.p,null,\"家長羞辱她，說什麼「不讀書就去工地搬磚」「做人要爭氣，不爭氣還不如去死」「你這樣的人怎麼還不去死」「留把小刀給他自殺用吧」。她對此啞口無言，只能一個人哭泣，她沒有辦法做任何事，因為家長一整天都在羞辱她，拉扯她，大部分的時間都在與父母的拉扯之間浪費掉了。\"),\"\\n\",Vue.h(_components.p,null,\"她度過了毫無意義的半年。直到中考前一天，她才回到了學校。父母還威脅她，如果她考不上高中，就讓她去外面打工。\"),\"\\n\",Vue.h(_components.p,null,\"儘管頂著巨大的壓力，她還是考上了當地的普通高中。可在開學的時候，她害怕再度被羞辱。儘管她還是想要去上學的，但最終因著對曾經那段陰影的畏懼，她休學了。\"),\"\\n\",Vue.h(_components.p,null,\"雖說休了學，但她的父母也不願意讓她在家獨居，就以斷掉生活費相要挾，威脅她隨他們去廣東打工創業。\"),\"\\n\",Vue.h(_components.p,null,\"她的父母東拼西湊了三十萬元，在東莞開了一個小小的紡織染色工廠，工人都是他們的親戚，但沒有工資。\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 也被要求去幫他們工作，雖說工作很輕鬆，但工作時間很長很長，也沒有任何薪水。於是，她在一段時間之後就不願幹了，並將自己鎖進了房間裡，不吃不喝，因而她總是挨餓。最後還是不得不偶爾去工作來蹭飯吃。\"),\"\\n\",Vue.h(_components.p,null,\"可哪怕是工作也要一直被惡言相向。她被家人羞辱是個廢物，那種極大的惡意進一步加重了她的精神壓力。\"),\"\\n\",Vue.h(_components.h2,null,\"深夜中的光\"),\"\\n\",Vue.h(_components.p,null,\"在廣東的日子裡很孤獨，她只能趁著父母晚上回來睡覺的時間用他們的行動網路下載 Gal。\"),\"\\n\",Vue.h(_components.p,null,\"那時，她沒有任何社交，哪怕是在網路上。每天陪伴她的只有 Gal 遊戲裡中的小人，以此來度過煎熬的每一天。\"),\"\\n\",Vue.h(_components.p,null,\"她很羨慕蘭斯。那是一個永遠可以無憂無慮地大冒險的角色，不管做什麼朋友們也總是陪伴著他。\"),\"\\n\",Vue.h(_components.p,null,\"她很羨慕緹娅\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-2\",id:\"footnote-ref-2\"},\"2\")),\"，能成為風守護自己的愛人。\"),\"\\n\",Vue.h(_components.p,null,\"她也很羨慕朋也\",Vue.h(\"sup\",null,Vue.h(\"a\",{href:\"#footnote-3\",id:\"footnote-ref-3\"},\"3\")),\"，作為普通人度過了平凡而幸福的一生。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我的很多夢想什麼的也都是在那時候有的，比如想要變得幸福什麼的，不過終究是不可能的吧……\"),\"\\n\",Vue.h(_components.p,null,\"雖然那時候吃不飽，沒有任何朋友，還整天要被辱罵。\"),\"\\n\",Vue.h(_components.p,null,\"但是我還是很懷念那個時候，懷念這些紙片人陪伴我度過的每一天，感謝他們一直陪伴著孤單的我。\"),\"\\n\",Vue.h(_components.p,null,\"孤單而痛苦的日子雖然很漫長，但這些遊戲卻是為數不多一直照耀著我的光芒了。\"),\"\\n\",Vue.h(_components.p,null,\"可我卻沒能追上這些光芒而一直沉淪了下去……\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"神明大人\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 有著強烈的宗教傾向，因而在她的心中，總有著一位「神明大人」。\"),\"\\n\",Vue.h(_components.p,null,\"雖然她並不知道神明大人是誰，但她一直堅信著神明大人總有一天會來拯救她。\"),\"\\n\",Vue.h(_components.p,null,\"從前，她總是會對著「神明大人」祈禱，為某人祈禱，為明天而祈禱。\"),\"\\n\",Vue.h(_components.p,null,\"肚子餓了的時候，她會向「神明大人」禱告。\"),\"\\n\",Vue.h(_components.p,null,\"飯前禱告之時，她會感激神明大人的庇護，因為她覺得是神明大人讓她不用忍飢挨餓了。\"),\"\\n\",Vue.h(_components.p,null,\"有時候，她也會覺得神明大人很過分，一點點的恩澤也不願意分給她。\"),\"\\n\",Vue.h(_components.p,null,\"可自從某件事情以後，她再也不會祈禱了。\"),\"\\n\",Vue.h(_components.p,null,\"因為她感受到她的神明大人永遠不願意將光輝照耀到她的身上。\"),\"\\n\",Vue.h(\"blockquote\",null,Vue.h(CapDownQuote,{messages:[[\"哭著想著神明大人什麼時候能對我溫柔一點呢”\",\"“明天什麼時候能變得好起來呢”\"],[\"“我安慰自己明天就會好起來了”\",\"“只要等到明天什麼都會好起來的”\"],[\"“可是明天到來了終究還是和昨天一樣什麼都沒有變”\"],[\"“還是和昨天一樣噩夢般的日子”\",\"“也不知道什麼時候能結束”\",\"“生活簡直就是在做噩夢”\"],[\"“只有睡著的時候能休息”\",\"“大概從來沒有什麼神明大人”\"],[\"“但我還是忍不住想著……”\",\"<span style='font-size: 200%; font-weight: bold;'>“神明大人”</span>\"]]})),\"\\n\",Vue.h(_components.h2,null,\"活著\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 也一直在思考著關於生命的話題。\"),\"\\n\",Vue.h(_components.p,null,\"2021 年的夏天，生活的苦澀壓倒了她，她曾試圖從這個世界上解脫。兩年後，當她回想起那件事，卻覺得自己的生活越來越好了，反倒失去了去死的勇氣。\"),\"\\n\",Vue.h(_components.p,null,\"她讀余華的《活著》，看到那句「人是為了活著本身而活著，而不是為了活著之外的任何事物而活著」，於是寫下了這樣的話：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"這句話中的人，是一個大的集合，也就是說可以代入具體的人。\"),\"\\n\",Vue.h(_components.p,null,\"例如加加林也是一個人，那麼就可以得出結論，加加林活著是為了活著本身，而不是為了活著之外的任何事物活著，這樣這句話明顯就是錯誤。同樣地，可以代入任何歷史人物。\"),\"\\n\",Vue.h(_components.p,null,\"但是假如活著的意義就是活著，意思就是活著沒有意義了，就像是是說下雪的意義就是下雪一樣。這麼就可以得出結論那麼多的歷史人物活著都是無意義的。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"NIGHT 把這段道理說給自己聽，「活著」這個詞卻因此變得更加沉重。夜裡，她偷偷抹去眼淚，只給自己留下一句再簡單不過的話：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"明天也要努力活著。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"她想著，要如何活著才能像維根斯坦一樣在臨死時說「告訴他們我度過了幸福的一生」呢？\"),\"\\n\",Vue.h(_components.p,null,\"幾天之後，她寫道：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"嘛……我要是死去的話，只能說「我度過了一個不幸而充滿遺憾的一生。」\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"只可惜後來，NIGHT 感受到自己一直活在過去，她追逐的是過去的幸福，可她發現往昔的日子已然回不去了。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我也許是死在以前那些遙不可及的日子裡了，活下來只是個意外罷了。\"),\"\\n\",Vue.h(_components.p,null,\"就如《大亨小傳》中的最後那句話所言：\"),\"\\n\",Vue.h(_components.p,null,\"「我們奮力向前，宛如逆水行舟，與激流抗爭勇進，直至淹沒入歲月長河。」\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"熱水澡\"),\"\\n\",Vue.h(_components.p,null,\"平日裡，對她來說最幸福的時刻，就是洗熱水澡的時候。\"),\"\\n\",Vue.h(_components.p,null,\"所以她總是要洗很久很久……哪怕什麼也不做，就讓熱水一直灑在身上。\"),\"\\n\",Vue.h(_components.p,null,\"所以，她許下了一點小小的願望：\"),\"\\n\",Vue.h(_components.p,null,\"她希望她以後的房子能有個頂噴花灑，像淋雨一樣。這樣就不需要用手拿著花灑了。\"),\"\\n\",Vue.h(_components.p,null,\"然後就是……邊洗澡邊放歌，這樣就很幸福了。\"),\"\\n\",Vue.h(_components.p,null,\"「啊啦……我還沒有用過浴缸呢……」她說道。\"),\"\\n\",Vue.h(_components.p,null,\"「要是有恆溫浴缸就好啦……進去一直泡著一定會很舒服。」\"),\"\\n\",Vue.h(_components.h2,null,\"逃亡與喘息\"),\"\\n\",Vue.h(_components.p,null,\"2024 年春，她再也受不了父母和她們在廣東的小工廠，於是開始了自己的逃亡之旅。\"),\"\\n\",Vue.h(_components.p,null,\"她到長三角的一處賓館長租住下，雖然稍微平靜了些許，但生活還是不願意放過她。\"),\"\\n\",Vue.h(_components.p,null,\"「苦澀的酒如同苦澀的人生一樣，難以下嚥，卻不得不接受。」\"),\"\\n\",Vue.h(_components.p,null,\"在賓館裡，她因為睡得太沉，被賓館工作人員以為是自殺。雖然這樣的誤會造成了些許麻煩，但她卻感到一絲關懷。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"要是我真的有個家就好了，也就不用來賓館了。\"),\"\\n\",Vue.h(_components.p,null,\"也許我在做夢，我真的擁有了一個家，恍恍惚惚，我一定是在做夢。\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"即使是在外漂泊，她也依然保持著自己內心的善意，收留了一位身無分文、無家可歸的 MtF，還自掏腰包為她湊了離開的路費。\"),\"\\n\",Vue.h(_components.p,null,\"她本想走得更遠，但她累了。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"我本想去北京，去天津，還是更遠更遠的地方。\"),\"\\n\",Vue.h(_components.p,null,\"不過我太累啦，我就在南京定居下來吧，我哪都不想去了。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"絕筆\"),\"\\n\",Vue.h(_components.p,null,\"她不想被藥物控制情緒。\"),\"\\n\",Vue.h(_components.p,null,\"她把所有的藥都扔掉了。\"),\"\\n\",Vue.h(_components.p,null,\"她想要愛，卻又感受不到愛。\"),\"\\n\",Vue.h(_components.p,null,\"她想要離開，卻已失去了做決定的能力，於是擲出了命運的骰子。\"),\"\\n\",Vue.h(_components.p,null,\"骰子的結果，她沒有明說。但她還是決定再聽一聽天意。\"),\"\\n\",Vue.h(_components.p,null,\"但她活得太累了，再多的酒精也壓不住她心中的絕望……\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"以後我們再也不會相見了。\"),\"\\n\",Vue.h(_components.p,null,\"但是我想，到最後還是需要一聲小小的道別——\"),\"\\n\",Vue.h(_components.p,null,\"我的朋友，感謝你出現在我的生命中。\"),\"\\n\",Vue.h(_components.p,null,\"感謝你對我一直以來的陪伴。\"),\"\\n\",Vue.h(_components.p,null,\"明天清早醒來，又會是嶄新的一天。\"),\"\\n\",Vue.h(_components.p,null,\"只是我再也沒有明天了，我再也無法為你的明天祈禱。\"),\"\\n\",Vue.h(_components.p,null,\"所以這次，我由衷地祝福你，希望你幸福。\"),\"\\n\",Vue.h(_components.p,null,\"請忘記我吧。\"),\"\\n\",Vue.h(_components.p,null,\"最後，再見……\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"或許，她的離開，真的是因為那句「自己的幸福永遠地停留在過去」……\"),\"\\n\",Vue.h(_components.p,null,\"也正如她所喜愛的《大亨小傳》結尾中所言吧：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"So we beat on, boats against the current, borne back ceaselessly into the past.\"),\"\\n\",Vue.h(_components.p,null,\"我們奮力向前，宛如逆水行舟，與激流抗爭勇進，直至淹沒入歲月長河。\"),\"\\n\"),\"\\n\",Vue.h(_components.h2,null,\"遲來的問候\"),\"\\n\",Vue.h(_components.p,null,\"自她離世一年以後，我們再度聽到了來自她的問候：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"這是一條來自 2024 年的定時推文哦。\"),\"\\n\",Vue.h(_components.p,null,\"今天是我的生日呢，請祝我生日快樂~\"),\"\\n\",Vue.h(_components.p,null,\"一年過去啦，大家變得怎麼樣了呢？\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"親愛的 NIGHT，世界或許在變糟，但我們一直在努力。\"),\"\\n\",Vue.h(_components.p,null,\"哪怕世界沒有變得更好，我們也在不斷嘗試變得更好。\"),\"\\n\",Vue.h(_components.p,null,\"以及，生日快樂。\"),\"\\n\",Vue.h(\"ol\",null,Vue.h(\"li\",{id:\"footnote-1\"},\"即「伏地挺身」\",Vue.h(\"a\",{href:\"#footnote-ref-1\"},Vue.h(\"svg\",{viewBox:\"0 0 16 16\",version:\"1.1\",id:\"svg1\",\"xmlns:xlink\":\"http://www.w3.org/1999/xlink\",xmlns:\"http://www.w3.org/2000/svg\",\"xmlns:svg\":\"http://www.w3.org/2000/svg\",style:\"margin-left: 0.5rem; margin-bottom: -2px; width: 1rem; height: 1rem\"},Vue.h(\"defs\",{id:\"defs1\"},Vue.h(\"linearGradient\",{id:\"linearGradient3\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop3\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop4\"})),Vue.h(\"linearGradient\",{id:\"linearGradient1\"},Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:0;\",offset:\"0.5\",id:\"stop1\"}),Vue.h(\"stop\",{style:\"stop-color:#ff8373;stop-opacity:1;\",offset:\"0.5\",id:\"stop2\"})),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient1\",id:\"linearGradient2\",x1:\"2.6681123\",y1:\"8\",x2:\"13.331888\",y2:\"8\",gradientUnits:\"userSpaceOnUse\",gradientTransform:\"translate(2.6678295,-2)\"}),Vue.h(\"linearGradient\",{\"xlink:href\":\"#linearGradient3\",id:\"linearGradient4\",x1:\"3.7075224\",y1:\"8\",x2:\"12.292478\",y2:\"8\",gradientUnits:\"userSpaceOnUse\"})),Vue.h(\"g\",{id:\"layer1\",transform:\"translate(0,2)\"},Vue.h(\"circle\",{style:\"fill:#cccccc;fill-opacity:0;stroke:url(#linearGradient2);stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",id:\"path1\",cx:\"10.667834\",cy:\"6\",r:\"4.5818877\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opacity:0;stroke:#ff8373;stroke-width:1.5;stroke-linecap:square;paint-order:stroke fill markers\",d:\"M 9.9178343,10.577036 H 1.7971455\",id:\"path2\"}),Vue.h(\"path\",{style:\"fill:#cccccc;fill-opaci