"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({a:\"a\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"簡介\"),\"\\n\",Vue.h(_components.p,null,\"Coin 是個熱情、追求自在的女孩子。她喜歡《原神》裡的角色宵宮，所以我們平日裡也常常叫她宵宮。\"),\"\\n\",Vue.h(_components.p,null,\"濁酒、涼秀、紗兒是她最在乎的人。\"),\"\\n\",Vue.h(_components.p,null,\"Coin 喜歡吃蔥和馬鈴薯泥，平日裡總是悉心照顧我們。她做的飯菜不僅僅是飯菜，還攜著她的那份溫暖與真誠。\"),\"\\n\",Vue.h(_components.p,null,\"她的家庭環境不好，為求獨立經濟來源，之前有段時間，她在《三角洲行動》中做護航服務來賺錢。\"),\"\\n\",Vue.h(_components.p,null,\"然而自始至終，她都背負著來自家人的沉重壓力，未獲得應有的關心與理解。\"),\"\\n\",Vue.h(_components.p,null,\"朋友小瑤的逝去讓她本就不穩定的精神狀態雪上加霜，她極度悲傷與內耗。我們很害怕她也那樣做，可是還是沒能挽留住她，現實生活將她徹底壓垮了。她常常失眠，只能依靠藥物才能勉強入睡。\"),\"\\n\",Vue.h(_components.p,null,\"她曾借過很多花唄（中國大陸的一種消費信貸服務），但大多數不是為自己，而是為朋友，她對朋友總是細心且多愁善感。\"),\"\\n\",Vue.h(_components.p,null,\"初到武漢時，她幾乎什麼也沒帶。她走的時候沒有在朋友的住處留下任何東西，卻把自己永遠留在了武漢。\"),\"\\n\",Vue.h(_components.p,null,\"當我們回到她曾經睡過的房間時，房間裡空蕩蕩的，幾乎沒有一件能代表她的物品，只有一件她生前穿過的衣服和她曾吃過的精神類藥物。\"),\"\\n\",Vue.h(_components.p,null,\"她彷彿還在我們身邊，但我們再也找不回她了。\"),\"\\n\",Vue.h(_components.p,null,\"她應該真的很絕望吧，被發現時就安靜地躺在他鄉的旅館當中，已然無力回天。\"),\"\\n\",Vue.h(_components.p,null,\"她悄無聲息地離開了，什麼都沒有說。\"),\"\\n\",Vue.h(_components.p,null,\"不再痛苦啦。在彼岸，你永遠是那個最自在的女孩子，願你永遠幸福。\"),\"\\n\",Vue.h(_components.p,null,\"條目貢獻：\",Vue.h(_components.a,{href:\"https://github.com/ShintoKosei\"},\"ShintoKosei\")))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout,_extends({},props),Vue.h(_createMdxContent,_extends({},props))):_cr