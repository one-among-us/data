"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({a:\"a\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"简介\"),\"\\n\",Vue.h(_components.p,null,\"Coin 是个热情、追求自在的女孩子。她喜欢《原神》里的角色宵宫，所以我们平日里也常常叫她宵宫。\"),\"\\n\",Vue.h(_components.p,null,\"浊酒、凉秀、纱儿是她最在乎的人。\"),\"\\n\",Vue.h(_components.p,null,\"Coin 喜欢吃葱和土豆泥，平日里总是悉心照顾我们。她做的饭菜不仅仅是饭菜，还携着她的那份温暖与真诚。\"),\"\\n\",Vue.h(_components.p,null,\"她的家庭环境不好，为求独立经济来源，之前有段时间，她在《三角洲行动》中做护航服务来赚钱。\"),\"\\n\",Vue.h(_components.p,null,\"然而自始至终，她都背负着来自家人的沉重压力，未获得应有的关心与理解。\"),\"\\n\",Vue.h(_components.p,null,\"朋友小瑶的逝去让她本就不稳定的精神状态雪上加霜，她极度悲伤与内耗。我们很害怕她也那样做，可是还是没能挽留住她，现实生活将她彻底压垮了。她常常失眠，只能依靠药物才能勉强入睡。\"),\"\\n\",Vue.h(_components.p,null,\"她曾借过很多花呗，但大多数不是为自己，而是为朋友，她对朋友总是细心且多愁善感。\"),\"\\n\",Vue.h(_components.p,null,\"初到武汉时，她几乎什么也没带。她走的时候没有在朋友的住处留下任何东西，却把自己永远留在了武汉。\"),\"\\n\",Vue.h(_components.p,null,\"当我们回到她曾经睡过的房间时，房间里空荡荡的，几乎没有一件能代表她的物品，只有一件她生前穿过的衣服和她曾吃过的精神类药物。\"),\"\\n\",Vue.h(_components.p,null,\"她仿佛还在我们身边，但我们再也找不回她了。\"),\"\\n\",Vue.h(_components.p,null,\"她应该真的很绝望吧，被发现时就安静地躺在他乡的酒店当中，已然无力回天。\"),\"\\n\",Vue.h(_components.p,null,\"她悄无声息地离开了，什么都没有说。\"),\"\\n\",Vue.h(_components.p,null,\"不再痛苦啦。在彼岸，你永远是那个最自在的女孩子，愿你永远幸福。\"),\"\\n\",Vue.h(_components.p,null,\"条目贡献：\",Vue.h(_components.a,{href:\"https://github.com/ShintoKosei\"},\"ShintoKosei\")))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout,_extends({},props),Vue.h(_createMdxContent,_extends({},props))):_createMdxContent(p