"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({a:\"a\",blockquote:\"blockquote\",em:\"em\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"The Transit Enthusiast\"),\"\\n\",Vue.h(_components.p,null,\"MocaKawai took her name from Aoba Moca of \",Vue.h(_components.em,null,\"BanG Dream!\"),\".\\nWhichever Moca you have in mind,\\nboth are impossibly endearing,\\nboth a little scatterbrained — the kind of person you can’t help but look at twice.\"),\"\\n\",Vue.h(_components.p,null,\"As a transit enthusiast,\\nMoca played a wide range of simulation and management games,\\nincluding \",Vue.h(_components.em,null,\"Rail Route\"),\" and \",Vue.h(_components.em,null,\"Cities: Skylines\"),\".\\nShe would often stare at route maps, lost in thought, designing the perfect transit network for some imaginary city.\"),\"\\n\",Vue.h(_components.p,null,\"She also played \",Vue.h(_components.em,null,\"Fall Guys\"),\" and \",Vue.h(_components.em,null,\"Among Us\"),\".\\nShe was always warm and lively in the comment sections of her videos, sometimes sharing little tips and tricks with her friends there.\"),\"\\n\",Vue.h(_components.p,null,\"Having lived in Sanya for most of her life, Moca knew the city’s public transit system inside and out.\\nShe filmed a great many transit-related videos, the majority of which were front-window POVs of Sanya’s bus routes.\"),\"\\n\",Vue.h(_components.p,null,\"For those who follow transit POVs, what matters most is not the footage itself, it is the mood.\\nA different route, a different hour, a different state of mind, and the POV becomes something else entirely, something hard to put into words.\\nMoca understood this.\\nShe gave each of her POV videos a carefully chosen title, passing on that sense of being \",Vue.h(_components.em,null,\"there\"),\" to her friends:\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"“Express from the two major hubs straight to the westernmost tip of Sanya”\"),\"\\n\",Vue.h(_components.p,null,\"“Drifting into nightfall in the hypnotic sway of a sightseeing route at China’s southernmost point”\"),\"\\n\",Vue.h(_components.p,null,\"“Racing uphill through a downpour”\"),\"\\n\",Vue.h(_components.p,null,\"“Chasing the sunset on the expressway!”\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"In September 2022, confined at home during the COVID-19 pandemic,\\nMoca created a schematic map of \",Vue.h(_components.a,{href:\"https://www.bilibili.com/read/cv18624078\"},\"Sanya’s rapid transit network\"),\".\\nNearly a year later, she \",Vue.h(_components.a,{href:\"https://www.bilibili.com/read/cv2497345811\"},\"revisited and refined the map\"),\", adding several intercity routes to the original design.\"),\"\\n\",Vue.h(_components.p,null,\"Her love for transit was much like the titles she wrote.\\nEvery bit of it sincere, and quietly romantic.\"),\"\\n\",Vue.h(_components.h2,null,\"Escape from the Island\"),\"\\n\",Vue.h(_components.p,null,\"In the summer of 2023, Moca’s mental health deteriorated sharply for a number of reasons, and she began to overdose.\\nThe pressure of her final year of high school soon followed.\\nAt the end of August, a suicide attempt landed her in the ICU.\\nShe survived, but things did not truly get better.\\nAfter being discharged, she lost her partner, lost her friends, and her physical condition worsened.\"),\"\\n\",Vue.h(_components.p,null,\"Afterwards, Moca took a leave of absence from school.\\nShe had few friends in Sanya, so she decided to travel to the Yangtze River Delta — to wander through cities she had never been to before.\\nThe trip allowed her to meet friends she had only known online, and for a while, it eased some of her pain.\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"Tried savoury doufunao (tofu pudding) for the first time? Not really my thing. Long live sweet doufunao!\"),\"\\n\",Vue.h(_components.p,null,\"McDonald’s! It’s so much cheaper outside Sanya, I’m so jealous…\"),\"\\n\",Vue.h(_components.p,null,\"The sticky rice is delicious! Totally different from what you get in Sanya!\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"For a brief moment, she had escaped the island — not just the geographical one, but the one inside her mind.\"),\"\\n\",Vue.h(_components.p,null,\"But after returning to Hainan,\\nthe darkness closed in again.\\nHer continued misuse of medication only made things worse.\\nThe substance she had purchased during her travels ultimately took her life after she returned to Sanya.\\nShe did not make it through that autumn.\"),\"\\n\",Vue.h(_components.p,null,\"“It’s so damp… or maybe that’s just my tears…”\"),\"\\n\",Vue.h(_components.p,null,\"Rain or shine, silence or rush hour... All of it was scenery that Moca wanted to share with us.\\nEvery route she cared about, she recorded with care and posted for her fellow transit lovers to see.\"),\"\\n\",Vue.h(_components.p,null,\"She always liked to sit at the very front of the bus, watching the road unfold through the wide windscreen ahead.\"),\"\\n\",Vue.h(_components.p,null,\"This last ride, though, had no final stop.\"))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout,_extends({},props),Vue.h(_createMdxContent,_extends({},props))):_createMdxContent(props)}"