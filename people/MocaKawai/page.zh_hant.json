"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({a:\"a\",blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"交通迷摩卡\"),\"\\n\",Vue.h(_components.p,null,\"摩卡好可愛的名字來源於《BanG Dream!》的青葉摩卡。無論是哪個「摩卡」，都很惹人可愛，也都會偶爾犯迷糊，讓人忍不住多看一眼呢。\"),\"\\n\",Vue.h(_components.p,null,\"作為交通迷之一，摩卡遊玩過包括《鐵道調度模擬器》、《大都會：天際》在內的多款模擬經營遊戲。她常常會盯著線路圖思考，為某座虛擬的城市量身定做交通規劃。\"),\"\\n\",Vue.h(_components.p,null,\"此外，她也遊玩過《糖豆人》、《太空狼人殺》。她總是熱情地與影片留言區中的朋友們互動，有時候還會傳授大家一些遊戲小技巧。\"),\"\\n\",Vue.h(_components.p,null,\"因為長期在三亞生活的緣故，她對這座城市的公共交通系統瞭如指掌。她拍攝了許多交通相關的影片，其中最多的就是三亞公車的前方展望 POV。\"),\"\\n\",Vue.h(_components.p,null,\"對於關注交通 POV 的人來說，最重要的是心境。不同的路線，不同的時間，不同的情緒，都會給 POV 添加一種獨特的說不太清楚的東西。摩卡細心地給她的 POV 影片取了這樣多不同的標題，將那種身歷其境的感覺傳遞給朋友們：\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"「從兩大樞紐高速直達三亞最西端」\"),\"\\n\",Vue.h(_components.p,null,\"「在中國最南端觀光線催眠的搖車中逐漸入夜」\"),\"\\n\",Vue.h(_components.p,null,\"「在暴雨中飛車上山」\"),\"\\n\",Vue.h(_components.p,null,\"「在高速上朝著夕陽進發！」\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"在 2022 年 9 月，摩卡受到疫情影響居留家中。在此期間，她製作了\",Vue.h(_components.a,{href:\"https://www.bilibili.com/read/cv18624078\"},\"三亞市公共交通系統快線示意圖\"),\"。而時隔近一年之後，她再度將之前所製作的示意圖\",Vue.h(_components.a,{href:\"https://www.bilibili.com/read/cv2497345811\"},\"優化改進\"),\"，並在此前的基礎上添加了多條城際線路。\"),\"\\n\",Vue.h(_components.p,null,\"她對公車的熱愛就如同她寫下的那些標題一般，每一分都真切而浪漫。\"),\"\\n\",Vue.h(_components.h2,null,\"逃離孤島\"),\"\\n\",Vue.h(_components.p,null,\"2023 年暑假，因為各種原因，摩卡的精神狀態變得很差，開始過量用藥。高三的課業壓力隨後也撲面而來。八月末，她因為自殺進了一次 ICU，雖然保住了性命，但也並沒有真正好轉。出院後，她失去了對象，失去了朋友，身體也較之前變得更差。\"),\"\\n\",Vue.h(_components.p,null,\"在那之後，摩卡請假了一段時間。她在三亞沒什麼朋友，於是她決定前往長三角，到陌生的城市走一走。這場旅行讓她見到了之前在網路上認識的好朋友，也讓她忘卻了不少煩惱。\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"第一次嘗試鹹豆花？感覺不是很好吃誒。甜豆花萬歲！\"),\"\\n\",Vue.h(_components.p,null,\"麥麥！三亞之外的麥都好便宜，好羨慕……\"),\"\\n\",Vue.h(_components.p,null,\"糯米飯好吃！和三亞買到的不一樣！\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"她終於從精神的孤島上短暫地逃了出來，得以短暫喘息。\"),\"\\n\",Vue.h(_components.p,null,\"但回到海南之後，她先前的情緒陰翳再次反撲。連續不斷的過量用藥讓她的精神狀態雪上加霜。而旅行之中順手買下的「藥物」在她回到三亞之後摧毀了她的生命，她最終沒能撐過那個秋天。\"),\"\\n\",Vue.h(_components.p,null,\"「好潮哇……也可能是我的眼淚吧……」\"),\"\\n\",Vue.h(_components.p,null,\"無論天氣是暴雨還是放晴，無論周圍是靜謐還是早晚尖峰，都是摩卡想要留給我們的風景。那些她所在意的路線都被她認真記錄下來，而後分享給每個熱愛交通的朋友們。\"),\"\\n\",Vue.h(_components.p,null,\"她總是習慣坐在車頭，看著大玻璃窗的視野中，道路向前鋪開。\"),\"\\n\",Vue.h(_components.p,null,\"只是這最後一趟車，沒有終點站。\"))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout,_extends({},props),Vue.h(_createMdxContent,_extends({},props))):_createMdxContent(props)}"