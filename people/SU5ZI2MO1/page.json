"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"简介\"),\"\\n\",Vue.h(_components.p,null,\"世界上总是有这么些傻傻的人，舍弃了自己最后的希望来帮助其他人。\"),\"\\n\",Vue.h(_components.p,null,\"阿陌就是这样的人。\"),\"\\n\",Vue.h(_components.p,null,\"她所在的原生家庭并不幸福，那些常人唾手可得的关爱，对她来说却是镜花水月。\"),\"\\n\",Vue.h(_components.p,null,\"我们已经无从得知她的家庭如何对她，她在生活之中又经历了些什么。当我们能「看见」她时，她早已失去了对未来可能性的眷恋。\"),\"\\n\",Vue.h(_components.p,null,\"早在 2023 年初，阿陌就已开始想着买各种用来自杀的药物了。与此同时，她不顾账号风险和自身安危，通过各种渠道，将自己辛苦挣来的钱分给各路的朋友们。或许是被骗的同道人，或许是信用卡透支的同类，或许是走投无路的陌生人……\"),\"\\n\",Vue.h(_components.p,null,\"有许多被援助者都感激她的无私，当然也有少量江湖骗子趁虚而入。\"),\"\\n\",Vue.h(_components.p,null,\"也有些人怜惜着她，骂她傻。\"),\"\\n\",Vue.h(_components.p,null,\"「你没有爱的人？」\"),\"\\n\",Vue.h(_components.p,null,\"「没有了……」\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"有好多话想说却说不出口，终于，我可以解脱了。\"),\"\\n\",Vue.h(_components.p,null,\"活着是如此煎熬，不知道该说些什么，如果我能出生在正常家庭，如果我能再多感受一些爱，我的人生会不会大变样呢？\"),\"\\n\",Vue.h(_components.p,null,\"可惜，有太多如果，却没有成真一个。希望下辈子生在一个幸福的家庭，至少不要像现在这样，就好。\"),\"\\n\",Vue.h(_components.p,null,\"感谢大家一直以来的关心，希望看到我的大家可以一直开心下去哦~\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"她在临走前把所有的希望和温暖都给了别人，然后在冰冷的孤独之中和这个世界说了再见。\"),\"\\n\",Vue.h(_components.p,null,\"世上少了一个痛苦的孩子，却也少了一抹笨拙的温柔。\"),\"\\n\",Vue.h(_components.p,null,\"条目贡献：One Among Us, 白，零号，造林，silvicky\"))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout