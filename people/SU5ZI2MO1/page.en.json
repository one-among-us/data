"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"Introduction\"),\"\\n\",Vue.h(_components.p,null,\"There are always people like this in the world, quietly giving up their last bit of hope to help others.\"),\"\\n\",Vue.h(_components.p,null,\"Mo was one of them.\"),\"\\n\",Vue.h(_components.p,null,\"Her family of origin was not a happy one.\\nThe care and affection that others could easily take for granted felt to her like an unreachable illusion.\"),\"\\n\",Vue.h(_components.p,null,\"We may never know what her family was like, or what she went through in her life.\\nBy the time we were able to truly “see” her, she had already lost her attachment to the possibilities of the future.\"),\"\\n\",Vue.h(_components.p,null,\"Since early 2023, Mo had begun thinking about purchasing various drugs for the purpose of ending her life.\\nAt the same time, regardless of the risks to her accounts and her own safety, she distributed the money she had worked hard to earn to people through various channels.\\nPerhaps they were fellow victims of scams, peers struggling with credit card debt, or simply desperate strangers with nowhere else to turn…\"),\"\\n\",Vue.h(_components.p,null,\"Many of those she helped were grateful for her selflessness.\\nOf course, there were also a few opportunists who took advantage of her kindness.\"),\"\\n\",Vue.h(_components.p,null,\"There were also people who pitied her and called her foolish.\"),\"\\n\",Vue.h(_components.p,null,\"“Is there no one you love?”\"),\"\\n\",Vue.h(_components.p,null,\"“No… there isn’t.”\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"There’s so much I want to say, but I can’t seem to say any of it. At last, I can be free.\"),\"\\n\",Vue.h(_components.p,null,\"Living has been so painful. I don’t even know what to say anymore. If I had been born into a normal family, if I could have felt a little more love, would my life have turned out completely differently?\"),\"\\n\",Vue.h(_components.p,null,\"Sadly, there are too many “ifs”, and not a single one came true. I hope that in my next life, I can be born into a happy family—at the very least, not like this.\"),\"\\n\",Vue.h(_components.p,null,\"Thank you to everyone who has cared about me all this time. I hope all of you who see this can continue to live happily.\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"Before she left, she gave all her hope and warmth to others, and then said goodbye to this world in a cold and quiet loneliness.\"),\"\\n\",Vue.h(_components.p,null,\"The world has lost a child in pain, and with her, a clumsy kind of gentleness.\"),\"\\n\",Vue.h(_components.p,null,\"Contributors for this entry: One Among Us, Bai, Linghao, Zaolin, silvicky\"))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout,_extends({},props),Vue.h(_createMdxContent,_extends({},props))):_createMdxContent(props)}"