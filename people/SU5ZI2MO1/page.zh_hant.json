"\"use strict\";Object.defineProperty(exports,\"__esModule\",{value:true});Object.defineProperty(exports,\"default\",{enumerable:true,get:function(){return MDXContent}});function _extends(){_extends=Object.assign||function(target){for(var i=1;i<arguments.length;i++){var source=arguments[i];for(var key in source){if(Object.prototype.hasOwnProperty.call(source,key)){target[key]=source[key]}}}return target};return _extends.apply(this,arguments)}function _createMdxContent(props){var _components=_extends({blockquote:\"blockquote\",h2:\"h2\",p:\"p\"},props.components);return Vue.h(Vue.Fragment,null,Vue.h(_components.h2,null,\"簡介\"),\"\\n\",Vue.h(_components.p,null,\"世界上總是有這麼些傻傻的人，捨棄了自己最後的希望來幫助其他人。\"),\"\\n\",Vue.h(_components.p,null,\"阿陌就是這樣的人。\"),\"\\n\",Vue.h(_components.p,null,\"她所在的原生家庭並不幸福，那些常人唾手可得的關愛，對她來說卻是鏡花水月。\"),\"\\n\",Vue.h(_components.p,null,\"我們已經無從得知她的家庭如何對她，她在生活之中又經歷了些什麼。當我們能「看見」她時，她早已失去了對未來可能性的眷戀。\"),\"\\n\",Vue.h(_components.p,null,\"早在 2023 年初，阿陌就已開始想著買各種用來自殺的藥物了。與此同時，她不顧帳號風險和自身安危，透過各種管道，將自己辛苦掙來的錢分給各路的朋友們。或許是被騙的同道人，或許是信用卡透支的同類，或許是走投無路的陌生人……\"),\"\\n\",Vue.h(_components.p,null,\"有許多被援助者都感激她的無私，當然也有少量江湖騙子趁虛而入。\"),\"\\n\",Vue.h(_components.p,null,\"也有些人憐惜著她，罵她傻。\"),\"\\n\",Vue.h(_components.p,null,\"「你沒有愛的人？」\"),\"\\n\",Vue.h(_components.p,null,\"「沒有了……」\"),\"\\n\",Vue.h(_components.blockquote,null,\"\\n\",Vue.h(_components.p,null,\"有好多話想說卻說不出口，終於，我可以解脫了。\"),\"\\n\",Vue.h(_components.p,null,\"活著是如此煎熬，不知道該說些什麼，如果我能出生在正常家庭，如果我能再多感受一些愛，我的人生會不會大變樣呢？\"),\"\\n\",Vue.h(_components.p,null,\"可惜，有太多如果，卻沒有成真一個。希望下輩子生在一個幸福的家庭，至少不要像現在這樣，就好。\"),\"\\n\",Vue.h(_components.p,null,\"感謝大家一直以來的關心，希望看到我的大家可以一直開心下去哦~\"),\"\\n\"),\"\\n\",Vue.h(_components.p,null,\"她在臨走前把所有的希望和溫暖都給了別人，然後在冰冷的孤獨之中和這個世界說了再見。\"),\"\\n\",Vue.h(_components.p,null,\"世上少了一個痛苦的孩子，卻也少了一抹笨拙的溫柔。\"),\"\\n\",Vue.h(_components.p,null,\"條目貢獻：One Among Us, 白，零號，造林，silvicky\"))}function MDXContent(props){if(props===void 0)props={};var _ref=props.components||{},MDXLayout=_ref.wrapper;return MDXLayout?Vue.h(MDXLayout